#!/bin/sh
# Ensure ~/.claude/settings.json wires Claude Code's lifecycle hooks to the
# `agent-state` script, which sets a per-window tmux user option that
# window-status-format reads to render the per-tab indicator dot:
#
#   UserPromptSubmit / PreToolUse → clear state — tab falls back to green
#                                                  while Claude is working
#   Stop                          → "idle"      — grey ○ when turn ends
#   Notification                  → "needs-input" — yellow ● when Claude
#                                                   wants explicit attention
#
# This is a chezmoi modify_ script: stdin = current target content, stdout
# = new content. Idempotent — overwrites only the four hook keys we manage
# and preserves every other setting Claude Code adds at runtime.

set -eu

input=$(cat)
[ -z "$input" ] && input='{}'

mk_hook() {
    # build a one-element hooks array invoking `agent-state <arg>`.
    # $HOME is left literal so /bin/sh expands it when Claude Code runs the hook.
    jq -n --arg cmd "\$HOME/.local/bin/agent-state $1" '[
        {
            "matcher": "",
            "hooks": [
                { "type": "command", "command": $cmd }
            ]
        }
    ]'
}

clear_hook=$(mk_hook "")
idle_hook=$(mk_hook "idle")
input_hook=$(mk_hook "needs-input")

printf '%s' "$input" | jq \
    --argjson clear "$clear_hook" \
    --argjson idle  "$idle_hook" \
    --argjson input "$input_hook" \
    '.hooks.UserPromptSubmit = $clear
   | .hooks.PreToolUse       = $clear
   | .hooks.Stop             = $idle
   | .hooks.Notification     = $input'
