#!/bin/sh
# Ensure ~/.claude/settings.json wires Claude Code's lifecycle hooks to the
# `agent-state` script, which sets a per-window tmux user option that
# window-status-format reads to render the per-tab indicator dot:
#
#   SessionStart                     → "none"        (no dot) a fresh session
#                                                     hasn't finished a turn, so
#                                                     it looks like a plain shell
#                                                     tab — yellow ○ would wrongly
#                                                     read as "your turn". Also
#                                                     clears any stale state left
#                                                     on a reused tmux window.
#   SessionEnd                       → "none"        the agent exited (quit, /clear,
#                                                     logout, prompt-input exit) —
#                                                     clear the dot so a finished tab
#                                                     dropped back to a bare shell
#                                                     doesn't keep a stale dot. (The
#                                                     zsh precmd reaper in
#                                                     dot_zshrc.tmpl is the backstop
#                                                     for Codex — which has no
#                                                     SessionEnd — and for hard
#                                                     crashes, which fire no hook.)
#   Stop                             → delegated to `agent-stop-state`, which
#                                                     reads the Stop payload and
#                                                     picks: "running" ● if the
#                                                     turn ended with in-flight
#                                                     background work that will
#                                                     auto-resume the agent;
#                                                     "needs-input" red ● if the
#                                                     final message ends with a
#                                                     question (turn ended asking
#                                                     the user something — see
#                                                     ~/.claude/CLAUDE.md); else
#                                                     "idle" ○.
#   UserPromptSubmit / PostToolUse   → "running"     blue ●  (Claude is working)
#   PreToolUse                       → "running"     blue ● — EXCEPT the two tools
#                                                     that block mid-turn waiting on
#                                                     the user: AskUserQuestion and
#                                                     ExitPlanMode (plan approval),
#                                                     which go "needs-input" red ●.
#                                                     Claude fires no Notification for
#                                                     these and no further hook runs
#                                                     while it waits, so without this
#                                                     branch the dot would sit blue as
#                                                     if working. PostToolUse restores
#                                                     running once the user answers.
#   Notification[permission_prompt]  → "needs-input" red ●   (blocked on an
#                                                     approval). The idle_prompt
#                                                     nudge is deliberately NOT
#                                                     hooked, so a finished tab
#                                                     stays yellow ○ instead of
#                                                     turning red after ~60s.
#
# This is a chezmoi modify_ script: stdin = current target content, stdout
# = new content. Idempotent — overwrites only the hook keys we manage and
# preserves every other setting Claude Code adds at runtime.

set -eu

input=$(cat)
[ -z "$input" ] && input='{}'

mk_hook() {
    # build a one-element hooks array invoking `agent-state <arg>` with an empty
    # matcher. The events these drive (SessionStart / SessionEnd / Stop /
    # PostToolUse) aren't filtered by tool name, so the matcher is always "".
    # $HOME is left literal so /bin/sh expands it when Claude Code runs the hook.
    jq -n --arg cmd "\$HOME/.local/bin/agent-state $1" '[
        {
            "matcher": "",
            "hooks": [
                { "type": "command", "command": $cmd }
            ]
        }
    ]'
}

none_hook=$(mk_hook "none")
running_hook=$(mk_hook "running")

# Notification fires for two cases, distinguished by the payload's
# "notification_type" field (NOT by the matcher — matchers only match tool
# names, so the old matcher:"permission_prompt" matched nothing and the dot
# never went red). We want red only for permission_prompt; idle_prompt (the
# ~60s "waiting for your input" nudge) must leave the dot alone so a finished
# tab stays idle instead of turning red. So: match all Notifications (matcher
# ""), then gate on notification_type inside the command. $HOME stays literal.
perm_cmd='if [ "$(jq -r .notification_type)" = permission_prompt ]; then $HOME/.local/bin/agent-state needs-input; fi'
perm_hook=$(jq -n --arg cmd "$perm_cmd" '[
    { "matcher": "", "hooks": [ { "type": "command", "command": $cmd } ] }
]')

# PreToolUse: normally "running", but AskUserQuestion and ExitPlanMode (plan
# approval) block mid-turn waiting on the user with NO Notification and no
# further hook until the user answers — so the generic running dot would sit
# blue as if Claude were working. Branch on the payload's tool_name (read once
# from stdin, same as perm_cmd) to send those two red instead; PostToolUse
# flips back to running the moment the user responds. Matcher stays "" — the
# tool-name test lives in the command, since matchers only gate which tools
# fire the hook and we want ALL PreToolUse events to reach this one script.
pretool_cmd='case "$(jq -r .tool_name)" in AskUserQuestion|ExitPlanMode) $HOME/.local/bin/agent-state needs-input ;; *) $HOME/.local/bin/agent-state running ;; esac'
pretool_hook=$(jq -n --arg cmd "$pretool_cmd" '[
    { "matcher": "", "hooks": [ { "type": "command", "command": $cmd } ] }
]')

# UserPromptSubmit: mark the tab running, except a bare `e` prompt exits — a
# shell-style `e`=exit. This is one sequential script rather than a separate
# exit hook on purpose: Claude Code may run an event's hooks concurrently, so a
# standalone exit hook would race the `running` set above and could leave the
# tab stuck on the running dot.
#
# The exit itself is delegated to `agent-exit` (also used by the /oneoff
# command), so there's a single source of truth for "leave this session". Inside
# tmux it kill-panes the whole tree; outside tmux (e.g. a Ghostty tab) it
# SIGTERMs Claude and SIGHUPs the launching shell so the tab closes too; and if
# the tmux server is unreachable (orphaned /tmp socket) it falls through to that
# same kill path. We pipe the hook payload into it (capture once into $p, reuse
# for the .prompt test) so it can read .transcript_path and scrub the bare `e`
# line from this session's log on the way out. $HOME stays literal so /bin/sh
# expands it at hook runtime.
prompt_cmd='p=$(cat); if [ "$(printf "%s" "$p" | jq -r .prompt)" = e ]; then printf "%s" "$p" | $HOME/.local/bin/agent-exit; else $HOME/.local/bin/agent-state running; fi'
prompt_hook=$(jq -n --arg cmd "$prompt_cmd" '[
    { "matcher": "", "hooks": [ { "type": "command", "command": $cmd } ] }
]')

# Stop: the turn ended — delegated to `agent-stop-state` because the decision now
# needs the payload read twice (background_tasks AND the final message text), and
# a single jq can only consume stdin once. That script picks running ● (in-flight
# background work will auto-resume the agent), needs-input red ● (final message
# ends with a question — the agent ended its turn asking the user something, the
# one waiting-on-user case Claude Code exposes no native signal for), or idle ○
# otherwise. $HOME stays literal so /bin/sh expands it when Claude Code runs the
# hook; the script reads the payload from stdin itself.
stop_cmd='$HOME/.local/bin/agent-stop-state'
stop_hook=$(jq -n --arg cmd "$stop_cmd" '[
    { "matcher": "", "hooks": [ { "type": "command", "command": $cmd } ] }
]')

# Status line: a Catppuccin-coloured Starship-style line (path, git branch,
# model, ctx%). The script lives in chezmoi too (executable_statusline-command.sh
# → ~/.claude/statusline-command.sh); we inject the wiring here so a fresh
# machine gets it. $HOME is expanded now (apply time) into an absolute path —
# Claude Code runs `command` without shell expansion, so a literal ~ or $HOME
# would not resolve.
status_cmd="bash $HOME/.claude/statusline-command.sh"

printf '%s' "$input" | jq \
    --argjson none    "$none_hook" \
    --argjson running "$running_hook" \
    --argjson prompt  "$prompt_hook" \
    --argjson pretool "$pretool_hook" \
    --argjson perm    "$perm_hook" \
    --argjson stop    "$stop_hook" \
    --arg     statuscmd "$status_cmd" \
    '.hooks.SessionStart     = $none
   | .hooks.SessionEnd       = $none
   | .hooks.UserPromptSubmit = $prompt
   | .hooks.PreToolUse       = $pretool
   | .hooks.PostToolUse      = $running
   | .hooks.Notification     = $perm
   | .hooks.Stop             = $stop
   | .statusLine             = { "type": "command", "command": $statuscmd }'
