#!/bin/sh
# Ensure ~/.claude/settings.json wires Claude Code's lifecycle hooks to the
# `agent-state` script, which sets a per-window tmux user option that
# window-status-format reads to render the per-tab indicator dot:
#
#   SessionStart                     → "idle"        yellow ○ (fresh session,
#                                                     awaiting input)
#   Stop                             → "idle"        yellow ○ when the turn is
#                                                     fully done, OR "running"
#                                                     blue ● when it ended with
#                                                     in-flight background work
#                                                     (a run_in_background shell,
#                                                     subagent, …) that will
#                                                     auto-resume the agent — a
#                                                     bare idle ○ there wrongly
#                                                     reads as "your turn". Keyed
#                                                     off the Stop payload's
#                                                     background_tasks array
#                                                     (Claude Code >= 2.1.145).
#   UserPromptSubmit / PreToolUse /
#   PostToolUse                      → "running"     blue ●  (Claude is working)
#   Notification[permission_prompt]  → "needs-input" red ●   (blocked on an
#                                                     approval). The idle_prompt
#                                                     nudge is deliberately NOT
#                                                     hooked, so a finished tab
#                                                     stays yellow ○ instead of
#                                                     turning red after ~60s.
#
# This is a chezmoi modify_ script: stdin = current target content, stdout
# = new content. Idempotent — overwrites only the hook keys we manage and
# preserves every other setting Claude Code adds at runtime.

set -eu

input=$(cat)
[ -z "$input" ] && input='{}'

mk_hook() {
    # build a one-element hooks array invoking `agent-state <arg>` with an empty
    # matcher. The events these drive (SessionStart / Stop / Pre|PostToolUse)
    # aren't filtered by tool name, so the matcher is always "". $HOME is left
    # literal so /bin/sh expands it when Claude Code runs the hook.
    jq -n --arg cmd "\$HOME/.local/bin/agent-state $1" '[
        {
            "matcher": "",
            "hooks": [
                { "type": "command", "command": $cmd }
            ]
        }
    ]'
}

idle_hook=$(mk_hook "idle")
running_hook=$(mk_hook "running")

# Notification fires for two cases, distinguished by the payload's
# "notification_type" field (NOT by the matcher — matchers only match tool
# names, so the old matcher:"permission_prompt" matched nothing and the dot
# never went red). We want red only for permission_prompt; idle_prompt (the
# ~60s "waiting for your input" nudge) must leave the dot alone so a finished
# tab stays idle instead of turning red. So: match all Notifications (matcher
# ""), then gate on notification_type inside the command. $HOME stays literal.
perm_cmd='if [ "$(jq -r .notification_type)" = permission_prompt ]; then $HOME/.local/bin/agent-state needs-input; fi'
perm_hook=$(jq -n --arg cmd "$perm_cmd" '[
    { "matcher": "", "hooks": [ { "type": "command", "command": $cmd } ] }
]')

# UserPromptSubmit: mark the tab running, except a bare `e` prompt exits — a
# shell-style `e`=exit. This is one sequential script rather than a separate
# exit hook on purpose: Claude Code may run an event's hooks concurrently, so a
# standalone exit hook would race the `running` set above and could leave the
# tab stuck on the running dot.
#
# On `e` inside tmux we `kill-pane`, which tears down the whole pane process
# tree — Claude Code, its launching shell, and any nested shells — in one shot,
# so the tmux tab closes (no more chasing it with extra `exit`s). This matches
# the `e` shell function in .bash_aliases, which also kill-panes. If there's no
# pane (outside tmux) OR kill-pane fails to reach the server (e.g. its /tmp
# socket was deleted, orphaning the server), we fall back to clearing the dot
# (the Stop hook never fires once the CLI is killed) and SIGTERM-ing Claude Code
# ($PPID of the hook). $HOME / $PPID / $TMUX_PANE stay literal so /bin/sh
# expands them when Claude Code runs the hook.
prompt_cmd='if [ "$(jq -r .prompt)" = e ]; then if [ -n "$TMUX_PANE" ] && tmux kill-pane -t "$TMUX_PANE" 2>/dev/null; then :; else $HOME/.local/bin/agent-state idle; kill -TERM "$PPID"; fi; else $HOME/.local/bin/agent-state running; fi'
prompt_hook=$(jq -n --arg cmd "$prompt_cmd" '[
    { "matcher": "", "hooks": [ { "type": "command", "command": $cmd } ] }
]')

# Stop: the turn ended. Default to idle ○, but if Claude yielded with in-flight
# background work still attached to the session (a run_in_background shell, a
# subagent, a monitor, …) it will auto-resume when that work completes, so the
# tab is NOT awaiting input — keep it on the running ● dot. The Stop payload
# carries these as the background_tasks array (Claude Code >= 2.1.145; absent on
# older builds, hence the `// []` guard → idle). session_crons (future scheduled
# wakeups) are deliberately ignored: the agent really is idle until they fire.
# $HOME stays literal so /bin/sh expands it when Claude Code runs the hook.
stop_cmd='if [ "$(jq -r "(.background_tasks // []) | length")" -gt 0 ]; then $HOME/.local/bin/agent-state running; else $HOME/.local/bin/agent-state idle; fi'
stop_hook=$(jq -n --arg cmd "$stop_cmd" '[
    { "matcher": "", "hooks": [ { "type": "command", "command": $cmd } ] }
]')

printf '%s' "$input" | jq \
    --argjson idle    "$idle_hook" \
    --argjson running "$running_hook" \
    --argjson prompt  "$prompt_hook" \
    --argjson perm    "$perm_hook" \
    --argjson stop    "$stop_hook" \
    '.hooks.SessionStart     = $idle
   | .hooks.UserPromptSubmit = $prompt
   | .hooks.PreToolUse       = $running
   | .hooks.PostToolUse      = $running
   | .hooks.Notification     = $perm
   | .hooks.Stop             = $stop'
