#!/bin/sh
# Ensure ~/.claude/settings.json wires Claude Code's lifecycle hooks to the
# `agent-state` script, which sets a per-window tmux user option that
# window-status-format reads to render the per-tab indicator dot:
#
#   SessionStart / Stop              → "idle"        yellow ○ (fresh session or
#                                                     turn done, awaiting input)
#   UserPromptSubmit / PreToolUse /
#   PostToolUse                      → "running"     blue ●  (Claude is working)
#   Notification[permission_prompt]  → "needs-input" red ●   (blocked on an
#                                                     approval). The idle_prompt
#                                                     nudge is deliberately NOT
#                                                     hooked, so a finished tab
#                                                     stays yellow ○ instead of
#                                                     turning red after ~60s.
#
# This is a chezmoi modify_ script: stdin = current target content, stdout
# = new content. Idempotent — overwrites only the hook keys we manage and
# preserves every other setting Claude Code adds at runtime.

set -eu

input=$(cat)
[ -z "$input" ] && input='{}'

mk_hook() {
    # build a one-element hooks array invoking `agent-state <arg>`. $1 = the
    # agent-state argument, $2 = the event matcher (default ""). $HOME is left
    # literal so /bin/sh expands it when Claude Code runs the hook.
    jq -n --arg cmd "\$HOME/.local/bin/agent-state $1" --arg matcher "${2:-}" '[
        {
            "matcher": $matcher,
            "hooks": [
                { "type": "command", "command": $cmd }
            ]
        }
    ]'
}

idle_hook=$(mk_hook "idle")
running_hook=$(mk_hook "running")
perm_hook=$(mk_hook "needs-input" "permission_prompt")

# UserPromptSubmit: mark the tab running, except a bare `e` prompt exits the
# session — a shell-style `e`=exit alias. This is one sequential script rather
# than a separate exit hook on purpose: Claude Code may run an event's hooks
# concurrently, so a standalone exit hook would race the `running` set above and
# could leave the tab stuck on the green dot. On `e` we reset the tab to idle
# first (killing the CLI means the Stop hook never fires to clear it), then
# SIGTERM Claude Code's own process ($PPID of the hook). $HOME/$PPID stay
# literal so /bin/sh expands them when Claude Code runs the hook.
prompt_cmd='if [ "$(jq -r .prompt)" = e ]; then $HOME/.local/bin/agent-state idle; kill -TERM "$PPID"; else $HOME/.local/bin/agent-state running; fi'
prompt_hook=$(jq -n --arg cmd "$prompt_cmd" '[
    { "matcher": "", "hooks": [ { "type": "command", "command": $cmd } ] }
]')

printf '%s' "$input" | jq \
    --argjson idle    "$idle_hook" \
    --argjson running "$running_hook" \
    --argjson prompt  "$prompt_hook" \
    --argjson perm    "$perm_hook" \
    '.hooks.SessionStart     = $idle
   | .hooks.UserPromptSubmit = $prompt
   | .hooks.PreToolUse       = $running
   | .hooks.PostToolUse      = $running
   | .hooks.Notification     = $perm
   | .hooks.Stop             = $idle'
