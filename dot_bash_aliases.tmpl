# Wrap `make` so `make serve`/`make docs` show a green port chip on the tab (next to the
# agent dot â€” see dot_tmux.conf) for the lifetime of the foreground server, then
# clears it on exit. A background server-port-watch sniffs out the listening
# port and fills it in. Every other make target passes straight through. The
# INT/TERM trap clears the chip on Ctrl-C; `command make` avoids recursing into
# this wrapper. The watcher is launched in a subshell â€” `( â€¦ & )` â€” so the shell
# prints no "[1] 12345" job line; it self-exits when @server_state leaves
# running (set below), so there's no PID to track or kill. Only tracks
# foreground servers â€” a target that detaches (docker compose up -d) returns
# immediately, so the chip clears even though the container stays up. See
# dot_local/bin/executable_server-state.
make() {
    # Glob, not exact: catches serve_test, serve-prod, etc. â€” any serve*/docs*
    # variant. server-port-watch is name-agnostic (it diffs listening ports), so
    # this gate is the only thing coupled to the target name.
    case "$1" in serve*|docs*) ;; *) command make "$@"; return ;; esac
    server-state running
    ( server-port-watch & )
    trap 'server-state off' INT TERM
    command make "$@"; local rc=$?
    server-state off
    trap - INT TERM
    return $rc
}

# LLMs
cc() {
    if [ $# -eq 0 ]; then
        claude --dangerously-skip-permissions
    else
        claude --dangerously-skip-permissions -p "$@"
    fi
}
ccc() {
    if [ $# -eq 0 ]; then
        claude --dangerously-skip-permissions --chrome
    else
        claude --dangerously-skip-permissions --chrome -p "$@"
    fi
}
ccp() {
    if [[ -f "$1" ]]; then
        # We pass the file content to cc, which handles the -p flag
        cc "$(cat "$1")"
    else
        echo "Error: File '$1' not found."
        return 1
    fi
}
# Start Claude in an isolated git worktree under .claude/worktrees/<name>/.
# Native worktree support handles branch creation, .worktreeinclude copying
# and cleanup on exit, so this is just a thin wrapper (cc() can't take flags â€”
# it folds every arg into -p). No name â†’ Claude generates one (and we can't
# rename the tab since we don't know it). Inside tmux, name the tab "cc <name>"
# so the worktree stands out in the prefix+w tree and prefix+o montage; the
# manual rename also disables automatic-rename-format, which would relabel it
# "claude" the moment the agent starts.
ccw() {
    if [ -n "$TMUX" ] && [ -n "$1" ]; then
        tmux rename-window "cc $1"
    fi
    claude --dangerously-skip-permissions --worktree "$@"
}
# Codex, fully auto-run (the cc â†’ claude analogue: co â†’ codex). `--yolo` (=
# --dangerously-bypass-approvals-and-sandbox) never prompts and drops the
# sandbox entirely. The earlier `-a never --sandbox workspace-write` setup was
# meant to keep writes confined, but the sandbox got in the way more than it
# helped â€” codex constantly tripped over blocked writes/network and needed
# escalations, so it's not worth it. Mirrors `cc`'s --dangerously-skip-
# permissions: trust the agent, lean on git to undo. A plain alias suffices â€”
# codex takes a positional prompt natively, so `co`, `co "<prompt>"` and
# `co exec "<prompt>"` all just work.
alias co='codex --yolo'
# Claude Code via Azure AI Foundry (Opus 4.8, Sweden Central) instead of the
# Anthropic subscription â€” routes inference + billing through the platform's
# `aif-nwf-claude` Foundry account, authenticating with your `az login` token
# (Entra ID, no API key). Opt-in: plain `cc` still uses the Anthropic plan.
# Needs `az login` in the warmtefonds tenant first; the account is defined in
# nwf-ai-platform-infra (infra/global/platform.bicep). opus-only account, so all
# three model aliases point at the one deployment â€” that way background tasks
# (title gen, etc.) don't 404 on a missing Sonnet/Haiku. Subshell keeps the
# Foundry env out of the parent shell.
cca() {
    (
        export CLAUDE_CODE_USE_FOUNDRY=1
        export ANTHROPIC_FOUNDRY_RESOURCE=aif-nwf-claude
        export ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-8
        export ANTHROPIC_DEFAULT_SONNET_MODEL=claude-opus-4-8
        export ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-opus-4-8
        if [ $# -eq 0 ]; then
            claude --dangerously-skip-permissions --model opus
        else
            claude --dangerously-skip-permissions --model opus -p "$@"
        fi
    )
}

# Toggle the Karabiner variable that switches Ghostty's âŒ˜V into smart image-paste
# (clipboard image â†’ uploaded to the remote box's /tmp â†’ its path typed) for the
# duration of a remote SSH session; plain-text pastes still paste normally. Pass 1
# on connect, 0 on disconnect. The -x guard makes this a no-op off macOS (e.g. when
# ~/.bash_aliases is sourced on a Linux box) or without Karabiner installed. Both
# devbox() and homelab() also reset it via a signal trap, so an abruptly-killed
# session (terminal window closed â†’ SIGHUP) can't leave the flag stuck at 1 and
# hijack âŒ˜V image-paste in local Ghostty windows. See ~/.local/bin/ssh-image-paste.
_remote_ssh_flag() {
  local kc='/Library/Application Support/org.pqrs/Karabiner-Elements/bin/karabiner_cli'
  [ -x "$kc" ] && "$kc" --set-variables "{\"remote_ssh_connected\":$1}" >/dev/null 2>&1
}

## Home server
# SSH into the homelab and drop into the timvink-homelab repo. A function, not an
# alias, so â€” like devbox() below â€” it can flag the Karabiner image-paste session
# (see _remote_ssh_flag) for the duration of the connection. The upload rides the
# reusable ControlMaster socket set up in ~/.ssh/config's `Host homelab` block.
homelab() {
  _remote_ssh_flag 1
  # Auto-mount ~/Downloads (read-only) at homelab:~/mac-downloads for this session
  # (see the reverse-mount helpers below); the backgrounded waiter brings it up once
  # the master is live, and it's torn down on exit. $_mnt is that waiter, killed in
  # case it's still polling when we leave.
  _revmount_bg homelab homelab &
  local _mnt=$!
  # Reset the flag and unmount even if the session dies abruptly (terminal closed â†’
  # SIGHUP, or killed) and skips the normal cleanup below; the handler clears itself
  # so the trap never leaks into the interactive shell. INT/TERM/HUP behave the same
  # in bash and zsh.
  trap "_remote_ssh_flag 0; kill $_mnt 2>/dev/null; _revumount homelab homelab; trap - INT TERM HUP" INT TERM HUP
  ssh -t homelab "cd /media/storage/private/timvink-homelab/ && exec \$SHELL -l"
  kill "$_mnt" 2>/dev/null
  _revumount homelab homelab
  trap - INT TERM HUP
  _remote_ssh_flag 0
}

# Unlock the encrypted ZFS dataset on the homelab after a reboot and
# restart services that mount paths under /media/storage/private/.
# Runs locally if on the homelab, otherwise SSH-es into `homelab`.
zfs_unlock() {
    local repo=/media/storage/private/timvink-homelab
    # The list of services to (re)start lives inside the repo (which is on
    # the encrypted dataset), so it is read AFTER the dataset is mounted.
    # See $repo/post-unlock-services.txt â€” single source of truth.
    local stty_state
    printf "Enter ZFS passphrase for homelab: " >&2
    stty_state=$(stty -g 2>/dev/null || true)
    [ -n "$stty_state" ] && stty -echo
    IFS= read -r zfs_pass
    [ -n "$stty_state" ] && stty "$stty_state"
    printf "\n" >&2
    local cmd='
        set -e
        repo=/media/storage/private/timvink-homelab
        sudo zfs load-key raidpool/private
        sudo zfs mount raidpool/private
        while IFS= read -r svc; do
            [ -z "$svc" ] && continue
            case "$svc" in \#*) continue ;; esac
            [ -f "$repo/$svc/docker-compose.yml" ] &&
            docker compose --env-file "$repo/.env" -f "$repo/$svc/docker-compose.yml" up -d
        done < "$repo/post-unlock-services.txt"
        echo "Success!"
    '
    local rc
    if [ "$(hostname)" = "homelab" ]; then
        printf '%s\n' "$zfs_pass" | bash -c "$cmd"
        rc=$?
    else
        printf '%s\n' "$zfs_pass" | ssh -tt homelab "bash -c '$cmd'"
        rc=$?
    fi
    unset zfs_pass
    return $rc
}

## Azure
# SSH into my Azure devbox VM. Two tunnels ride the connection:
#   -D 1080  SOCKS proxy â†’ view any dev server as http://devbox:<port> (the PAC
#            in ~/.config/proxy.pac routes the `devbox` host through it; the box
#            resolves `devbox` to its own loopback).
#   -R 2489  reverse tunnel â†’ the box's xdg-open shim sends URLs back to the
#            open-url-listener here so links open in this Mac's browser.
# A third option rides it too: -o ControlMaster lets `ssh-image-paste` reuse this
# connection to stream a clipboard image into the box's /tmp on âŒ˜V. `devbox` is a
# function (not an alias) so it can also flag the Karabiner image-paste session
# (see _remote_ssh_flag) for the session's duration; the same flag is shared with
# homelab() above. See ~/.local/bin/xdg-open (box), and ~/.local/bin/open-url-listener +
# ~/.local/bin/ssh-image-paste (this Mac).
devbox() {
  _remote_ssh_flag 1
  # Auto-mount ~/Downloads (read-only) at devbox:~/mac-downloads for this session
  # (see the reverse-mount helpers below). The devbox waiter resolves User+host from
  # the live connection (the IP isn't known up-front), mounts once the master is up,
  # and is torn down on exit. $_mnt is that waiter, killed if still polling on exit.
  _revmount_bg_devbox &
  local _mnt=$!
  # Reset the flag and unmount even if the session dies abruptly (terminal closed â†’
  # SIGHUP, or killed) and skips the normal cleanup below; the handler clears itself
  # so the trap never leaks into the interactive shell. INT/TERM/HUP behave the same
  # in bash and zsh.
  trap "_remote_ssh_flag 0; kill $_mnt 2>/dev/null; _revumount_devbox; trap - INT TERM HUP" INT TERM HUP
  # --only-show-errors silences the ssh extension's unconditional "upgrade to
  # az ssh >=2.0.4" breaking-change banner (hardcoded in azext_ssh, fires on
  # every `az ssh vm` regardless of installed version) without hiding real
  # az errors like auth failures or a missing VM.
  #
  # LogLevel=FATAL stops the SSH client from scribbling "channel N: open failed:
  # connect failed: Connection refused" over the interactive TUI. Those come from
  # the -D 1080 SOCKS forward when a browser tab still points at a devbox:<port>
  # dev server that has since stopped (proxy.pac routes it through here, the box
  # refuses, and this master process â€” which also runs the shell â€” logs it onto the
  # same terminal). FATAL drops those error-level lines but still surfaces fatal
  # failures, so a refused connection / changed host key is never silently swallowed.
  az ssh vm -n vm-devbox-tim-vink -g rg-nwf-devbox-tim-vink --only-show-errors -- \
    -D 1080 -R 2489:127.0.0.1:2489 -o LogLevel=FATAL \
    -o ControlMaster=auto -o ControlPath="$HOME/.ssh/cm-devbox.sock" -o ControlPersist=30m
  kill "$_mnt" 2>/dev/null
  _revumount_devbox
  trap - INT TERM HUP
  _remote_ssh_flag 0
}

## Reverse ~/Downloads mounts
# devbox() and homelab() above auto-mount this Mac's ~/Downloads (read-only) onto the
# box as ~/mac-downloads for the life of the session, so from a remote shell you can
# just `cp ~/mac-downloads/foo.xlsx .` â€” no separate command to run or remember. It's
# a *reverse* sshfs: the FUSE mount lives on the Linux box (it has /dev/fuse +
# fusermount3); sshfs there runs in slave mode (-o slave), speaking SFTP over
# stdin/stdout instead of dialing out. On this side, `dpipe` (from the `vde` brew)
# wires the box's sshfs to our built-in /usr/libexec/sftp-server, so nothing new has
# to listen on the Mac â€” it all rides the SSH ControlMaster the connect function
# already set up. Read-only by design: pulling files out, never into it. Needs sshfs
# on each box (run_onchange_setup_packages_linux.sh) and vde on the Mac
# (.chezmoiscripts/â€¦_darwin.sh).
#
# Resolve "<user> <host>" for the live devbox connection without hardcoding the
# VM's public IP (it changes across deallocations): parse it off the `ssh <ip> -l
# <user> â€¦` child that az spawned, and cache it. Once an interactive session
# exits, ControlPersist retitles that process to "[mux]" and the args vanish, so
# in the persist window we fall back to the cache (trusted only while the master
# socket still exists). Empty if there's no usable connection at all.
_devbox_conn() {
  local cache="$HOME/.ssh/cm-devbox.conn" conn
  conn="$(ps -Ao args 2>/dev/null | grep -F 'cm-devbox.sock' | awk '
    {u="";h="";for(i=1;i<=NF;i++){if($i=="-l")u=$(i+1);if($i=="ssh")h=$(i+1)}
     if(u!=""&&h!=""){print u" "h; exit}}')"
  if [ -n "$conn" ]; then
    printf '%s\n' "$conn" > "$cache"
    printf '%s\n' "$conn"
  elif [ -S "$HOME/.ssh/cm-devbox.sock" ] && [ -f "$cache" ]; then
    cat "$cache"
  fi
}

# Bring up the bridge once. $1=tag (names the pidfile); rest = ssh destination args
# (OPTIONS FIRST, host last â€” ssh stops parsing options at the destination). No-op if
# dpipe is absent (e.g. when this file is sourced on a Linux box) or the bridge is
# already up. The remote sh expands ~ and $(id â€¦) on the box; "$macdl" (the Mac's
# Downloads path) is spliced in literally for the slave-mode sshfs to serve.
_revmount() {
  local tag="$1"; shift
  local pidfile="$HOME/.ssh/revmount-$tag.pid" macdl="$HOME/Downloads"
  command -v dpipe >/dev/null 2>&1 || return 0
  [ -f "$pidfile" ] && kill -0 "$(cat "$pidfile" 2>/dev/null)" 2>/dev/null && return 0
  dpipe /usr/libexec/sftp-server = \
    ssh -o RequestTTY=no -o BatchMode=yes "$@" \
      'mkdir -p ~/mac-downloads && exec sshfs :'"$macdl"' ~/mac-downloads -o slave,ro,reconnect,uid=$(id -u),gid=$(id -g)' &
  echo $! > "$pidfile"
}

# Background waiter: poll (~30s) until the master named by the ssh dest is up, then
# mount. Launch with a trailing & from the connect function. $1=tag; rest = ssh dest.
_revmount_bg() {
  command -v dpipe >/dev/null 2>&1 || return 0
  local tag="$1"; shift
  local i
  for i in $(seq 1 60); do
    if ssh -O check "$@" 2>/dev/null; then _revmount "$tag" "$@"; return 0; fi
    sleep 0.5
  done
}

# devbox variant: its dest (User + host) isn't known until az brings the session up,
# so resolve it from _devbox_conn on each poll. Launch backgrounded with a trailing &.
_revmount_bg_devbox() {
  command -v dpipe >/dev/null 2>&1 || return 0
  local conn user host i
  for i in $(seq 1 60); do
    conn="$(_devbox_conn)"
    if [ -n "$conn" ]; then
      read -r user host <<< "$conn"
      if ssh -O check -o ControlPath="$HOME/.ssh/cm-devbox.sock" -o User="$user" "$host" 2>/dev/null; then
        _revmount devbox -o ControlPath="$HOME/.ssh/cm-devbox.sock" -o User="$user" "$host"
        return 0
      fi
    fi
    sleep 0.5
  done
}

# Tear down tag's bridge: unmount on the box (best effort â€” killing the local bridge
# also EOFs the box's sshfs so it self-unmounts) then drop the local processes.
# $1=tag; rest = ssh dest args (may be empty if the box is no longer reachable).
_revumount() {
  local tag="$1"; shift
  local pidfile="$HOME/.ssh/revmount-$tag.pid" pid
  [ $# -gt 0 ] && ssh -o BatchMode=yes "$@" \
    'fusermount3 -u ~/mac-downloads 2>/dev/null || fusermount -u ~/mac-downloads 2>/dev/null' 2>/dev/null || true
  if [ -f "$pidfile" ]; then
    pid="$(cat "$pidfile" 2>/dev/null)"
    [ -n "$pid" ] && { kill "$pid" 2>/dev/null; pkill -P "$pid" 2>/dev/null; }
    rm -f "$pidfile"
  fi
}

# devbox teardown: resolve the dest while we still can (the socket persists ~30m after
# exit), else just kill the local bridge.
_revumount_devbox() {
  local conn user host
  conn="$(_devbox_conn)"
  if [ -n "$conn" ]; then
    read -r user host <<< "$conn"
    _revumount devbox -o ControlPath="$HOME/.ssh/cm-devbox.sock" -o User="$user" "$host"
  else
    _revumount devbox
  fi
}

