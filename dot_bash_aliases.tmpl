# git worktrees -- cd to main branch of worktree
gt_cdmain() {
    local common_dir
    common_dir=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || {
        echo "gt_cdmain: not inside a git repository" >&2
        return 1
    }
    cd "${common_dir}/.."
}

