# Bash commands
# `e` = leave this tmux tab. Plain `exit` only pops one shell level, so nested
# shells (a `chezmoi cd` subshell, a stacked `zsh`, etc.) need several `exit`s
# before the tab finally closes. `tmux kill-pane` destroys the pane's entire
# process tree at once, so one `e` always closes the tab. Outside tmux it just
# exits the shell. Matches the Claude Code `e` hook (see dot_claude/
# modify_settings.json), which kill-panes too. Note: over SSH ($TMUX is unset on
# the remote) `e` exits the remote shell first, as you'd want.
#
# If kill-pane can't reach the server (e.g. its /tmp socket was deleted, leaving
# the server orphaned), fall back to `exit` — that still closes the pane, since
# pane teardown happens over the pty, not the socket. The 2>/dev/null hides the
# "error connecting …" noise in that case.
e() {
    if [ -n "$TMUX" ]; then
        tmux kill-pane -t "${TMUX_PANE:-}" 2>/dev/null || exit
    else
        exit
    fi
}
alias c="clear"

# Keep tmux's socket out of /tmp. By default tmux puts its socket in
# /tmp/tmux-$UID/, which macOS's periodic cleaner (and a manual `rm` of /tmp)
# will happily delete out from under a running server. When that happens the
# server stays alive and the attached client keeps working, but NEW clients and
# hooks can't connect ("error connecting … No such file or directory") — so the
# agent-state dot updates silently no-op and the per-tab dots freeze. ~/.cache
# is persistent, so the socket survives any /tmp wipe. tmux won't create the
# parent dir itself, so ensure it exists.
export TMUX_TMPDIR="${TMUX_TMPDIR:-$HOME/.cache/tmux}"
[ -d "$TMUX_TMPDIR" ] || mkdir -p "$TMUX_TMPDIR"

# tmux — attach to the 'main' session, or create it if it doesn't exist yet.
#
# Always use `t` (or the full `tmux new -A -s main`) to start tmux, never
# plain `tmux`. Plain `tmux` runs `new-session`, which creates a *new*
# numbered session every time and silently orphans whatever you had
# running — defeating the persistence point of running tmux on the VM.
# The `-A` flag makes new-session attach if the named session already
# exists, so the same one-liner works on first login and on reconnect.
alias t='tmux new -A -s main'

