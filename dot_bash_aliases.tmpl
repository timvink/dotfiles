# Bash commands
# `e` = leave this tmux tab. Plain `exit` only pops one shell level, so nested
# shells (a `chezmoi cd` subshell, a stacked `zsh`, etc.) need several `exit`s
# before the tab finally closes. `tmux kill-pane` destroys the pane's entire
# process tree at once, so one `e` always closes the tab. Outside tmux it just
# exits the shell. Matches the Claude Code `e` hook (see dot_claude/
# modify_settings.json), which kill-panes too. Note: over SSH ($TMUX is unset on
# the remote) `e` exits the remote shell first, as you'd want.
#
# If kill-pane can't reach the server (e.g. its /tmp socket was deleted, leaving
# the server orphaned), fall back to `exit` — that still closes the pane, since
# pane teardown happens over the pty, not the socket. The 2>/dev/null hides the
# "error connecting …" noise in that case.
e() {
    if [ -n "$TMUX" ]; then
        tmux kill-pane -t "${TMUX_PANE:-}" 2>/dev/null || exit
    else
        exit
    fi
}
alias c="clear"

# Keep tmux's socket out of /tmp (macOS's periodic cleaner deletes it out from
# under a running server). The canonical export lives in ~/.zshenv so EVERY zsh
# — including non-interactive ones that may launch tmux — agrees on the socket;
# this copy just covers interactive bash, which never reads .zshenv. Keep the
# two in sync. See dot_zshenv for the full rationale.
export TMUX_TMPDIR="${TMUX_TMPDIR:-$HOME/.cache/tmux}"
[ -d "$TMUX_TMPDIR" ] || mkdir -p "$TMUX_TMPDIR"

# tmux — get me into my persistent dev server. If any session is running, attach
# to the most-recently-used one (every other session/tab is one prefix+w or
# prefix+s away). Only when the server is completely empty — all sessions and
# tabs closed — bootstrap a fresh 'chezmoi' workspace: cc in tab 1, nvim in tab 2,
# both rooted in the chezmoi source dir.
#
# Deliberately NOT tied to a session named 'main': `tmux new -A -s main` hardcodes
# that name, so renaming or killing your top session strands you on a fresh empty
# `main` even though the rest of your work is still alive in the server. Attaching
# by no name instead means t always resumes wherever you left off, and only
# bootstraps when there is literally nothing to attach to (the server exits once
# its last session closes, so `tmux ls` failing is that signal).
#
# Never start tmux with plain `tmux` — that runs `new-session` and spawns a new
# numbered session every time, orphaning your running work. Always use `t`.
#
# cc/nvim go through send-keys into an interactive shell: cc is a shell function,
# not on PATH; nvim so that quitting it drops you at a working shell, not a dead
# pane. Per-project workspaces live in prefix+f (the fuzzy project finder).
t() {
    [ -n "$TMUX" ] && return                     # already inside tmux
    if tmux ls >/dev/null 2>&1; then             # server up → resume where I left off
        tmux attach
    else                                         # server empty → bootstrap chezmoi
        local dir="$HOME/.local/share/chezmoi"
        tmux new-session -d -s chezmoi -c "$dir"
        tmux send-keys  -t chezmoi cc Enter
        tmux new-window -t chezmoi -c "$dir"
        tmux send-keys  -t chezmoi nvim Enter
        tmux select-window -t chezmoi:1
        tmux attach -t chezmoi
    fi
}

