Host github.com
  AddKeysToAgent yes
  IdentityFile ~/.ssh/id_ed25519

Host homelab
    HostName 192.168.68.200
    User timvink
    IdentityFile ~/.ssh/id_ed25519
    # Reverse tunnel so the headless homelab can open URLs in this Mac's browser:
    # its xdg-open shim sends the URL back down this to open-url-listener here.
    # (Harmless on non-dev `ssh homelab` sessions — at worst a "remote port
    # forwarding failed" notice if the port's already in use by another session.)
    RemoteForward 2489 127.0.0.1:2489
    # SOCKS proxy → view any dev server as http://homelab:<port> (its own port,
    # routed by ~/.config/proxy.pac). Needs homelab to resolve `homelab` -> loopback.
    DynamicForward 1081
    # Reusable authenticated connection. `ssh-image-paste` rides this same socket
    # to stream a clipboard image into the box's /tmp on ⌘V (no re-auth); 30m
    # persistence keeps it warm between pastes. The devbox session sets the
    # equivalent -o flags inline in its launcher (it has no Host block here).
    ControlMaster auto
    ControlPath ~/.ssh/cm-homelab.sock
    ControlPersist 30m
