# Fall back to xterm-256color if the terminfo entry for $TERM is missing.
# Happens when SSH-ing in from ghostty to a host without the xterm-ghostty entry.
if [ -n "${TERM:-}" ] && ! infocmp "$TERM" >/dev/null 2>&1; then
    export TERM=xterm-256color
fi

# Ensure ~/.local/bin is on PATH (where uv, agy, the nvim symlink etc. land).
# Mirrors dot_zshrc.tmpl; replaces lines the Antigravity CLI installer used to
# append to ~/.bash_profile and ~/.bashrc directly.
export PATH="$HOME/.local/bin:$PATH"

# ~/.cargo/bin holds cargo-installed tools (rbw, rbw-agent). Managed here rather
# than via rustup's appended `. ~/.cargo/env`, since chezmoi owns this file and
# would otherwise clobber that line on the next apply.
[ -d "$HOME/.cargo/bin" ] && export PATH="$HOME/.cargo/bin:$PATH"

# Source my aliases
if [ -f ~/.bash_aliases ]; then
    source ~/.bash_aliases
fi

# Source any private env vars
if [ -f ~/.bash_env ]; then
    source ~/.bash_env
fi

# Update path for claude code
export PATH="$HOME/.local/bin:$PATH"

## Pretty prompts, https://starship.rs/
if command -v starship >/dev/null 2>&1; then
    eval "$(starship init bash)"
fi
if command -v uv >/dev/null 2>&1; then
    eval "$(uv generate-shell-completion bash)"
fi

# don't put duplicate lines or lines starting with space in the history.
# See bash(1) for more options
HISTCONTROL=ignoreboth

# append to the history file, don't overwrite it
shopt -s histappend

# for setting history length see HISTSIZE and HISTFILESIZE in bash(1)
HISTSIZE=1000
HISTFILESIZE=2000
