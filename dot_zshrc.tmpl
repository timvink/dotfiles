# ----- Completions -----
autoload -Uz compinit && compinit

# Emacs-style line editing. Without this, zsh infers its keymap from $EDITOR,
# and because EDITOR=nvim contains "vi" it silently comes up in vi mode — whose
# insert keymap self-inserts Ctrl+A / Ctrl+E as literal "^A^E" instead of moving
# to line start / end (exactly the bytes Ghostty's Cmd+Left / Cmd+Right send).
# emacs mode binds the readline motions we actually use: Ctrl+A/E (line ends),
# Alt+b/f (word), Alt+Backspace (kill word). Must precede the binds below so
# they attach to the emacs keymap, not the vi one.
bindkey -e

# Alt+Left / Alt+Right jump words. Ghostty's default sent these as ESC b / ESC f
# (which zsh binds to word-motion by default), but that collided with the Alt+f
# tmux picker — both produced the same bytes. Ghostty now sends the standard
# modified-cursor CSI sequences instead (see dot_config/ghostty/config), so
# rebind word-motion onto those. ESC b / ESC f are now free for Alt+b / Alt+f.
bindkey '^[[1;3D' backward-word   # Alt+Left
bindkey '^[[1;3C' forward-word    # Alt+Right

# Source my aliases
source "$HOME/.bash_aliases"

# Source any private env vars
if [ -f ~/.bash_env ]; then
    source ~/.bash_env
fi

# Pretty prompts, https://starship.rs/
if command -v starship >/dev/null 2>&1; then
    eval "$(starship init zsh)"
fi

# Reap a stale per-tab agent dot. The agent-state script (driven by Claude/Codex
# lifecycle hooks) sets a tmux @agent_state dot and drops a per-pane sentinel
# file while a dot is live. Most exits get cleared by a hook (Claude's SessionEnd
# / the `e`-exit path), but Codex has no SessionEnd and a crash/SIGKILL fires no
# hook at all — so the dot would linger until the window is reused. While an
# agent runs it owns the pane's foreground, so this precmd can't fire; when the
# zsh prompt returns the agent is provably gone. If the sentinel is present,
# clear the dot. Gated on the cheap stat first, so agent-free panes fork nothing.
# The sentinel path MUST match executable_agent-state's formula exactly.
_agent_dot_reap() {
    [[ -n $TMUX_PANE && -e ${TMPDIR:-/tmp}/agent-dot-${TMUX_PANE#%} ]] || return
    agent-state none
}
autoload -Uz add-zsh-hook
add-zsh-hook precmd _agent_dot_reap

export HISTFILE=~/.zsh_history
export HISTSIZE=5000
export SAVEHIST=5000

# setopt autocd              # Just type folder name to cd
# setopt correct             # Spell-check commands
setopt histignorealldups   # No duplicate history entries
setopt sharehistory        # Share history across sessions

# Update path for claude code
export PATH="$HOME/.local/bin:$PATH"

# uv malware scanning: on `uv add` / `uv sync`, check the locked resolution
# against OSV malware (MAL) advisories and abort before any malicious code runs.
# Opt-in for now, so enable it everywhere. https://astral.sh/blog/uv-audit
export UV_MALWARE_CHECK=1

{{ if eq .chezmoi.os "darwin" }}
if [ -n "${HOMEBREW_PREFIX:-}" ]; then
    zsh_fast_syntax="$HOMEBREW_PREFIX/opt/zsh-fast-syntax-highlighting/share/zsh-fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh"
    zsh_autocomplete="$HOMEBREW_PREFIX/share/zsh-autocomplete/zsh-autocomplete.plugin.zsh"
    [ -r "$zsh_fast_syntax" ] && source "$zsh_fast_syntax"
    [ -r "$zsh_autocomplete" ] && source "$zsh_autocomplete"
    unset zsh_fast_syntax zsh_autocomplete
fi
{{ end }}

{{ if eq .chezmoi.os "linux" }}
{{  if eq .chezmoi.osRelease.id "ubuntu" }}
skip_global_compinit=1
{{  end }}
# Headless box: route URL-opening through my xdg-open shim, which forwards the
# URL to the browser on my host Mac over the SSH reverse tunnel (and falls back
# to printing a clickable link). Overrides cloud-init's /etc/profile.d default.
export BROWSER="$HOME/.local/bin/xdg-open"
{{ end }}

# fzf — fuzzy finder key bindings + completion.
#   ctrl-r  fuzzy history search      ctrl-t  insert file path
#   alt-c   cd into a subdir          **<tab> fuzzy-complete any command's arg
# Newer fzf (>=0.48, e.g. Homebrew) ships `fzf --zsh`; older apt builds don't,
# so fall back to sourcing the key-binding/completion files they drop on disk.
if command -v fzf >/dev/null 2>&1; then
    if fzf --zsh >/dev/null 2>&1; then
        eval "$(fzf --zsh)"
    else
        for d in /usr/share/doc/fzf/examples /usr/share/fzf; do
            [ -f "$d/key-bindings.zsh" ] && source "$d/key-bindings.zsh"
            [ -f "$d/completion.zsh" ]   && source "$d/completion.zsh"
        done
    fi
fi

# scaleway cli
if command -v scw >/dev/null 2>&1; then
    eval "$(scw autocomplete script shell=zsh)"
fi
