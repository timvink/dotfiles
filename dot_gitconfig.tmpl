[core]
	excludesfile = ~/.gitignore-global
	editor = "nvim"
	pager = diff-so-fancy | less --tabs=4 -RF

[user]
	name = Tim Vink
	email = vinktim@proton.me
	signingkey = 629C45DA26A97B48

# Conditional config
[includeIf "gitdir:~/workspace/work/"]
    path = ~/.gitconfig-work

[push]
	autoSetupRemote = true

[pull]
	rebase = false

[format]
	pretty = format:%C(auto)%h %d%Creset %s%n%Cgreen%ad%Creset %aN <%aE>%n

[interactive]
	diffFilter = diff-so-fancy --patch

{{ if eq .chezmoi.os "darwin" -}}
[gpg]
    program = /opt/homebrew/bin/gpg
{{- end }}

{{ if eq .chezmoi.os "darwin" -}}
[commit]
	gpgsign = true
{{- end }}

{{ if eq .chezmoi.os "darwin" -}}
# Git Credential Manager — browser/Entra OAuth for Azure Repos, GitHub, etc.
# Installed via Homebrew; the empty first helper resets inherited helpers (e.g. osxkeychain).
[credential]
	helper =
	helper = /usr/local/bin/git-credential-manager
[credential "https://dev.azure.com"]
	useHttpPath = true
{{- end }}

{{ if eq .chezmoi.os "linux" -}}
# Linux (remote VMs): authenticate GitHub HTTPS via the gh CLI, which holds the
# OAuth token (`gh auth login`). Equivalent to `gh auth setup-git`, but kept in
# source so `chezmoi apply` doesn't clobber it. PATH-resolved `gh` so it works
# regardless of install location. The empty first helper resets inherited ones.
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
{{- end }}
