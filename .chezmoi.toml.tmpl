{{- /* Prompted once per machine by `chezmoi init`; the answer is baked into
       ~/.config/chezmoi/chezmoi.toml. Re-run `chezmoi init` to change it. */ -}}
{{- $vaultAccess := promptBoolOnce . "vaultAccess" "This machine can reach the home vault (rbw) for apply-time secrets?" false -}}
{{- $codingAgent := promptChoiceOnce . "codingAgent" "Primary coding agent on this machine (drives tab 1 of the `t` tmux bootstrap)" (list "claude" "codex") "claude" -}}
# ~/.config/chezmoi/chezmoi.toml — generated by `chezmoi init` from
# .chezmoi.toml.tmpl in the source repo. Edit the template, not this file.
#
# vaultAccess gates apply-time templates that pull secrets from the home vault
# (rbw) — e.g. the Proton VPN wireguard conf. Machines off the vault mesh (work
# devbox, throwaway VMs) answer "no", so `chezmoi apply` never calls `rbw get`
# and never prompts to unlock. Defaults to false, so a machine whose config
# predates this flag is safe until it re-inits.
#
# codingAgent picks which agent the `t` tmux bootstrap launches in tab 1 (and,
# via tmux automatic-rename, what that tab is called): "claude" → `cc`, "codex"
# → `co`. The work devbox runs codex; my Macs run claude. Consumers read it with
# `dig "codingAgent" "claude" .` so a machine whose config predates this flag
# falls back to claude until it re-inits.
[data]
    vaultAccess = {{ $vaultAccess }}
    codingAgent = {{ $codingAgent | quote }}

[edit]
    command = "code"
    args = ["--wait"]
