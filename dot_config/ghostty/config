theme = Catppuccin Mocha
# JetBrains Mono (Nerd Font patch — keeps the icon glyphs the tmux status bar
# draws). Ghostty enables ligatures (calt/liga) by default, so -> => != >= etc.
# render as ligatures with no extra config; add `font-feature = -calt` to disable.
font-family = JetBrainsMono Nerd Font
font-size = 14

# Tabs — Cmd-based, so Option/Alt stays free for tmux on remote machines.
# (super+j / super+k are taken by Ghostty defaults scroll_to_selection /
# clear_screen, hence the shift.)
keybind = super+n=new_tab
keybind = super+shift+j=next_tab
keybind = super+shift+k=previous_tab

# Send the left Option key as Alt/Meta so tmux's M- bindings work over SSH.
# The right Option key still types special characters (#, accents, …).
macos-option-as-alt = left

# Free up ESC f / ESC b for use as Alt+f / Alt+b bindings. Ghostty's DEFAULT
# maps Alt+Left/Right to esc:b / esc:f (readline word-motion) — the exact same
# bytes a plain Alt+b / Alt+f produce, so tmux can't tell Alt+Right from Alt+f
# and an `M-f` binding fires on Alt+Right too (see dot_tmux.conf's Alt+f picker).
# Remapping the arrows to the standard modified-cursor CSI sequences makes them
# distinct keys (tmux sees M-Right / M-Left). Word-motion is re-added on those
# sequences in zsh (see dot_zshrc.tmpl), so Alt+arrow still jumps words.
keybind = alt+arrow_left=csi:1;3D
keybind = alt+arrow_right=csi:1;3C

# Alt+Down → end of line. Claude Code's prompt (and zsh) hard-code end-of-line to
# Ctrl+E and only honour the readline Meta bytes (ESC f / ESC b) for word motion —
# they ignore the modified-cursor CSI that Alt+Down otherwise sends, which is why
# it went dead once a fresh tmux server started forwarding the modifier intact.
# A bare 0x05 (Ctrl+E) is understood by both and passes through tmux untouched
# regardless of extended-keys. (Symmetric Alt+Up → start of line is `text:\x01`.)
keybind = alt+arrow_down=text:\x05

# Shift+Enter → newline (insert, don't submit). Send a bare LF (0x0a) — the exact
# byte Ctrl+J produces — instead of letting Shift+Enter ride the CSI-u extended
# key (ESC[13;2u). Codex's TUI (0.142) has a regression where it ignores that
# CSI-u sequence but still treats a literal LF as a newline; Claude Code documents
# Ctrl+J (= bare LF) as a newline key too, so this satisfies both. LF passes
# through tmux untouched, so no dependency on extended-keys for this one.
keybind = shift+enter=text:\n

