#!/bin/sh
# Watch for the TCP port(s) a `make serve` server starts listening on and
# publish them (space-separated) to the current tmux window's @server_port
# option, so the status bar and prefix+o overview can show e.g. "8000 8080".
#
# How: snapshot every LISTEN port at startup (the baseline), then poll and treat
# any port that appears *after* that as belonging to this serve. Diffing against
# a baseline — rather than walking make's process tree — is what lets this catch
# docker-published ports too: those are opened by the Docker daemon / vpnkit /
# docker-proxy, not by a child of make, so a tree walk would miss them. We
# publish ALL the new ports, not a guessed "main" one: a docker compose stack
# routinely publishes several (api + web + …) from the same daemon PID, so
# there's no reliable way to single one out — the picker lists each so you
# choose. (If some unrelated server starts mid-serve it's also caught, but
# that's rare on a dev box.)
#
# Lifetime: started fire-and-forget by the make wrapper (dot_bash_aliases.tmpl),
# which sets @server_state to running before launching us and back to off when
# `make serve` exits (normal exit, Ctrl-C, or a detached server). We poll that
# flag and exit the moment it leaves "running" — so the wrapper needs no PID and
# can launch us silently in a subshell. No-op outside tmux. Resolves its window
# once from $TMUX_PANE (inherited from the wrapper).

[ -n "${TMUX_PANE:-}" ] || exit 0
win=$(tmux display-message -t "$TMUX_PANE" -p '#{window_id}' 2>/dev/null) || exit 0
[ -n "$win" ] || exit 0

# Numeric LISTEN ports, one per line, sorted. -n: no host lookup, -P: numeric
# ports — both keep $9 as IP:PORT so the last ":"-field is always the port
# (handles *:3000, 127.0.0.1:3000 and [::1]:3000 alike). Works on macOS + Linux.
ports() {
    lsof -nP -iTCP -sTCP:LISTEN 2>/dev/null \
        | awk 'NR>1 {n=split($9,a,":"); print a[n]}' \
        | sort -un
}

base=$(mktemp) || exit 0
# A signal trap in sh runs the handler and then *resumes* the script unless it
# exits — so INT/TERM must explicitly exit, or the loop would spin on a
# already-deleted $base and spew "grep: … No such file". EXIT cleans up on the
# normal (self-terminating) path. grep's stderr is muted as a belt-and-braces
# guard against the same race.
trap 'rm -f "$base"' EXIT
trap 'rm -f "$base"; exit' INT TERM
ports > "$base"

interval=1
while [ "$(tmux show-options -wv -t "$win" '@server_state' 2>/dev/null)" = running ]; do
    # All ports that appeared after baseline, sorted ascending, capped, joined
    # with spaces. Capped at 6 so a stack that publishes a db/cache/etc. can't
    # blow up the chip width.
    new=$(ports | grep -vxF -f "$base" 2>/dev/null | head -6 | tr '\n' ' ' | sed 's/ *$//')
    if [ -n "$new" ]; then
        tmux set-option -wt "$win" '@server_port' "$new" 2>/dev/null || true
        interval=5   # found at least one; relax the poll
    fi
    sleep "$interval"
done
