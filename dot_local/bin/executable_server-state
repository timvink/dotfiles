#!/bin/sh
# Set the @server_state user option on the current tmux window. The tmux
# window-status-format reads it to render a per-tab "server is up" indicator:
#
#   running → green ■ :PORT  (a foreground server is holding this tab; the port
#                             is filled in by server-port-watch once detected)
#   off     → nothing        (no server, or the server exited)
#
# Driven by the `make` wrapper in dot_bash_aliases.tmpl, which flips it to
# `running` for the lifetime of `make serve` and back to `off` on exit. This is
# the foreground-process analog of `agent-state` (see that script): it tracks a
# server only while it occupies the tab. A server that detaches (e.g.
# `docker compose up -d`) returns immediately, so the square clears even though
# the container keeps running — that case needs polling, which this doesn't do.
#
# Usage: server-state running|off
#
# No-op outside tmux. Always exits 0 so the caller never sees an error.

state="${1:-}"

if [ -n "${TMUX_PANE:-}" ]; then
    win=$(tmux display-message -t "$TMUX_PANE" -p '#{window_id}' 2>/dev/null)
    if [ -n "${win:-}" ]; then
        tmux set-option -wt "$win" '@server_state' "$state" 2>/dev/null || true
        # Clear any port from a previous run so a new serve starts blank until
        # server-port-watch detects this run's port.
        if [ "$state" = off ]; then
            tmux set-option -wt "$win" '@server_port' "" 2>/dev/null || true
        fi
    fi
fi

exit 0
