#!/bin/sh
# ssh-image-paste — smart ⌘V for terminal SSH sessions, invoked by Karabiner when
# ⌘V is pressed in Ghostty during a remote session (the Azure devbox or the
# homelab). See the `devbox`/`homelab` functions in ~/.bash_aliases and the
# matching rule in ~/.config/karabiner/karabiner.json.
#
# Why this exists: pasting an IMAGE into a program running over SSH can't work
# the normal way — the program reads the *box's* clipboard (headless X11,
# unreachable), and a terminal ⌘V only sends text keystrokes, never image bytes.
# So when the Mac clipboard holds an image we stream it as a file into the box's
# /tmp over the SAME ssh connection (reused via ControlMaster, no re-auth) and
# type the resulting path. Codex, neovim and Claude Code all accept an image by
# path, so handing them the path is all they need. Plain-text pastes (and any
# paste when no remote session is up) are passed straight through as a normal ⌘V.
#
# Managed by chezmoi (macOS only).
#
# Security: the upload rides an authenticated SSH ControlMaster socket created by
# `devbox`/`homelab`; nothing new is opened. We only ever write to /tmp on the
# box, and the remote filename is a fixed timestamp+pid pattern (never
# clipboard-derived), so a hostile clipboard can't influence the remote command.

export PATH="/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

# Known reusable ControlMaster sessions, in priority order: "<host> <socket>".
# The first one with a live master wins (you'd rarely have both connected in the
# same Ghostty window; if you do, devbox is preferred). To teach this about a new
# host, add its ControlPath socket here and have its launcher set the Karabiner
# remote_ssh_connected flag.
SESSIONS="devbox $HOME/.ssh/cm-devbox.sock
homelab $HOME/.ssh/cm-homelab.sock"

# Normal paste of whatever's on the clipboard. osascript posts a synthetic ⌘V at
# the CGEvent layer, which is downstream of Karabiner's HID grab — so it reaches
# the app directly and does NOT re-trigger this rule (no paste loop).
paste_now() {
  osascript -e 'tell application "System Events" to keystroke "v" using command down'
}

# 1s debounce — belt-and-suspenders against any paste loop.
LOCK="/tmp/.ssh-image-paste.lock"
if [ -f "$LOCK" ] && [ "$(( $(date +%s) - $(stat -f %m "$LOCK" 2>/dev/null || echo 0) ))" -lt 1 ]; then
  exit 0
fi
: > "$LOCK"

# Grab a clipboard image into a local temp. No image on the clipboard → pngpaste
# fails → it's an ordinary (text) paste.
img="/tmp/ssh-image-paste.$$.png"
if ! pngpaste "$img" 2>/dev/null; then
  rm -f "$img"; paste_now; exit 0
fi

# Find the first remote session with a live master to ferry the image over.
# None up → ordinary paste.
host= sock=
while read -r h s; do
  [ -n "$h" ] || continue
  if [ -S "$s" ] && ssh -S "$s" -O check "$h" >/dev/null 2>&1; then
    host=$h; sock=$s; break
  fi
done <<EOF
$SESSIONS
EOF
if [ -z "$host" ]; then
  rm -f "$img"; paste_now; exit 0
fi

# Stream it into the box's /tmp over the existing connection, then type the path.
# On any failure, fall back to a normal paste so a ⌘V is never silently lost.
remote="/tmp/clip-$(date +%Y%m%d-%H%M%S)-$$.png"
if ssh -S "$sock" "$host" "umask 077; cat > '$remote'" < "$img" 2>/dev/null; then
  osascript -e "tell application \"System Events\" to keystroke \"$remote \""
else
  paste_now
fi
rm -f "$img"
