#!/bin/sh
# Set the @agent_state user option on the current tmux window. The tmux
# window-status-format reads it to render a per-tab agent indicator dot:
#
#   running     → blue   ●  (agent is working: producing output, or its turn
#                            ended with in-flight background work — a
#                            run_in_background shell, subagent, … — that will
#                            auto-resume it; either way, don't expect a prompt)
#   needs-input → red    ●  (agent is blocked on a question / approval)
#   idle        → yellow ○  (turn complete or fresh session, awaiting a prompt)
#
# Driven entirely by the Claude Code and Codex lifecycle hooks (see
# dot_claude/modify_settings.json and dot_codex/private_hooks.json). Tabs that
# never run an agent (shells, nvim, …) never set @agent_state, so they show no
# dot at all.
#
# Usage: agent-state running|idle|needs-input
#
# No-op outside tmux. Always exits 0 so the agent doesn't surface an error.

state="${1:-}"

if [ -n "${TMUX_PANE:-}" ]; then
    win=$(tmux display-message -t "$TMUX_PANE" -p '#{window_id}' 2>/dev/null)
    if [ -n "${win:-}" ]; then
        tmux set-option -wt "$win" '@agent_state' "$state" 2>/dev/null || true
    fi
fi

exit 0
