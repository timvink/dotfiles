#!/bin/sh
# Set the @agent_state user option on the current tmux window. The tmux
# window-status-format reads it to render a per-tab agent indicator dot:
#
#   running     → blue   ●  (agent is working: producing output, or its turn
#                            ended with in-flight background work — a
#                            run_in_background shell, subagent, … — that will
#                            auto-resume it; either way, don't expect a prompt)
#   needs-input → red    ●  (agent is blocked on a question / approval)
#   idle        → yellow ○  (turn complete, awaiting a prompt — "your turn")
#   none        → (no dot) (clears the option: a fresh session that hasn't
#                            finished a turn yet looks like a plain shell tab.
#                            Set on SessionStart so a new session isn't yellow
#                            and a reused window drops any stale prior state.)
#
# Driven entirely by the Claude Code and Codex lifecycle hooks (see
# dot_claude/modify_settings.json and dot_codex/private_hooks.json). Tabs that
# never run an agent (shells, nvim, …) never set @agent_state, so they show no
# dot at all.
#
# Usage: agent-state running|idle|needs-input|none
#
# No-op outside tmux. Always exits 0 so the agent doesn't surface an error.

state="${1:-}"

if [ -n "${TMUX_PANE:-}" ]; then
    # Per-pane sentinel: present on disk exactly while this pane's window carries
    # an @agent_state dot. The zsh precmd reaper (dot_zshrc.tmpl) stat-checks it
    # to cheaply decide whether to clear a stale dot when the shell prompt
    # returns — the backstop for exits that fire no clearing hook (Codex has no
    # SessionEnd; a crash/SIGKILL fires nothing). Keep this path formula byte-for-
    # byte identical to the reaper's, or the two won't agree on the file.
    sentinel="${TMPDIR:-/tmp}/agent-dot-${TMUX_PANE#%}"
    win=$(tmux display-message -t "$TMUX_PANE" -p '#{window_id}' 2>/dev/null)
    if [ -n "${win:-}" ]; then
        if [ "$state" = none ]; then
            # Unset the option entirely → no dot, and a reused window doesn't
            # carry a stale state from a previous agent session.
            tmux set-option -wt "$win" -u '@agent_state' 2>/dev/null || true
            rm -f "$sentinel" 2>/dev/null || true
        else
            tmux set-option -wt "$win" '@agent_state' "$state" 2>/dev/null || true
            : > "$sentinel" 2>/dev/null || true
        fi
    fi
fi

exit 0
