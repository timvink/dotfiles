#!/usr/bin/env python3
"""tmux-overview — a live full-screen montage of every tmux tab.

Bound to prefix+o. One band per session, a column per window (tab), each showing
a colour-preserving snapshot of that window's screen. Over each cell floats a
label box ("KEY name") filled with the window's @agent_state colour. A window
running a foreground `make serve` gets a green box with its port(s) appended
(e.g. "3 api  8000"), so servers stand out from agents.

Navigate: hjkl (or arrow keys) move a peach highlight between cells, wrapping at
every edge; Enter opens the highlighted cell. Or jump straight to a cell by its
KEY — 1-9 then a-z (skipping the h/j/k/l/q keys) — or by clicking it with the
mouse. q or Esc closes. Nothing is highlighted until you first move.

    blue ● running    red ● waiting    yellow ○ idle    green ■ server

Redraws in place each tick (~1s) — content, then separators, then boxes, then
the highlight on top — without clearing, so it stays current with minimal
flicker. Opened with -E so the script exiting closes the popup.
"""

import os
import re
import select
import shutil
import subprocess
import sys
import unicodedata

ESC = "\033"
RESET = f"{ESC}[0m"
BOLD = f"{ESC}[1m"

# Catppuccin Mocha
MAUVE = (203, 166, 247)
BLUE = (137, 180, 250)
RED = (243, 139, 168)
YELLOW = (249, 226, 175)
GREEN = (166, 227, 161)
PEACH = (250, 179, 135)   # selection highlight — distinct from every state colour
DIM = (108, 112, 134)
SEP = (88, 91, 112)
INK = (30, 30, 46)
SNOW = (235, 235, 245)

STATE = {"running": BLUE, "needs-input": RED, "idle": YELLOW}
OTHER = DIM
INTERVAL = 1.0

# Direct-jump hotkeys: 1-9 then letters, SKIPPING the hjkl nav keys and the q
# quit key so a jump can never be read as a move or a quit.
_RESERVED = set("hjklq")
HOTKEYS = [str(d) for d in range(1, 10)] + [c for c in "abcdefghijklmnopqrstuvwxyz" if c not in _RESERVED]

CSI = re.compile(r"\033\[[0-9;:?]*[ -/]*[@-~]")


def fg(rgb):
    return f"{ESC}[38;2;{rgb[0]};{rgb[1]};{rgb[2]}m"


def bg(rgb):
    return f"{ESC}[48;2;{rgb[0]};{rgb[1]};{rgb[2]}m"


def char_width(ch):
    if unicodedata.combining(ch):
        return 0
    return 2 if unicodedata.east_asian_width(ch) in ("W", "F") else 1


def vis_width(s):
    return sum(char_width(c) for c in s)


def strip_ansi(s):
    return CSI.sub("", s)


def crop_plain(s, width):
    out, w = [], 0
    for ch in s:
        cw = char_width(ch)
        if w + cw > width:
            break
        out.append(ch)
        w += cw
    return "".join(out)


def cell_ansi(s, width):
    """Crop to `width` visible cols keeping SGR escapes, then pad to width."""
    out, w, i, n = [], 0, 0, len(s)
    while i < n:
        if s[i] == ESC:
            m = CSI.match(s, i)
            if m:
                out.append(m.group())
                i = m.end()
                continue
            i += 1
            continue
        if s[i] in ("\t", "\r", "\n"):
            i += 1
            continue
        cw = char_width(s[i])
        if w + cw > width:
            break
        out.append(s[i])
        w += cw
        i += 1
    out.append(RESET)
    out.append(" " * (width - w))
    return "".join(out)


def at(r, c):
    return f"{ESC}[{r};{c}H"


def tmux(*args):
    return subprocess.run(
        ["tmux", *args], capture_output=True, text=True, encoding="utf-8", errors="replace"
    ).stdout


def gather():
    sessions = [s for s in tmux("list-sessions", "-F", "#{session_name}").split("\n") if s]
    wins = {}
    maxcols = 1
    for s in sessions:
        rec = []
        listing = tmux(
            "list-windows", "-t", s, "-F",
            "#{window_index}\t#{window_name}\t#{@agent_state}\t#{@server_state}\t#{@server_port}",
        )
        for line in listing.split("\n"):
            if not line:
                continue
            idx, name, state, server, port = (line.split("\t", 4) + [""] * 4)[:5]
            cap = tmux("capture-pane", "-e", "-p", "-t", f"{s}:{idx}").split("\n")
            while cap and not strip_ansi(cap[-1]).strip():
                cap.pop()
            rec.append((idx, name, state, server, port, cap))
        wins[s] = rec
        maxcols = max(maxcols, len(rec))
    return sessions, wins, maxcols


def box_style(state, server):
    if server == "running":
        return bg(GREEN) + fg(INK) + BOLD
    if state in STATE:
        return bg(STATE[state]) + fg(INK) + BOLD
    return bg(OTHER) + fg(SNOW) + BOLD


def build_frame(cols, rows, sessions, wins, maxcols, sel, clear):
    if not sessions:
        return f"{ESC}[2J{at(1, 1)}no sessions", {}, [], []

    nsess = len(sessions)
    cell_w = max(6, (cols - (maxcols - 1)) // maxcols)
    content_h = max(1, (rows - 1 - nsess) // nsess)

    buf = [f"{ESC}[2J"] if clear else []
    boxes = []          # (ri, ci, cstart, cx, cell_w, content_h, label, state, server)
    sep_rows = []
    jumpmap = {}        # hotkey -> (session, idx)
    grid = []           # grid[ri] = [(session, idx), …] in column order, for nav/Enter
    hitboxes = []       # (top, left, bottom, right, (session, idx)) for mouse clicks
    g = 0               # running cell number across all sessions
    r = 1
    for ri, s in enumerate(sessions):
        fill = max(0, cols - 4 - vis_width(s))
        buf.append(at(r, 1) + fg(MAUVE) + BOLD + f"━━ {s} " + "━" * fill + RESET)
        cstart = r + 1
        rec = wins[s]
        rowcells = []
        for c in range(maxcols):
            cx = c * (cell_w + 1) + 1
            if c < len(rec):
                idx, name, state, server, port, cap = rec[c]
                hotkey = HOTKEYS[g] if g < len(HOTKEYS) else None
                g += 1
                label = f"{hotkey} {name}" if hotkey else name
                if server == "running" and port:
                    label = f"{label}  {port}"
                if hotkey:
                    jumpmap[hotkey] = (s, idx)
                rowcells.append((s, idx))
                hitboxes.append((cstart, cx, cstart + content_h - 1, cx + cell_w - 1, (s, idx)))
                disp = cap[-content_h:]
                disp = [""] * (content_h - len(disp)) + disp
                for i in range(content_h):
                    buf.append(at(cstart + i, cx) + cell_ansi(disp[i], cell_w))
                boxes.append((ri, c, cstart, cx, cell_w, content_h, label, state, server))
            else:
                for i in range(content_h):
                    buf.append(at(cstart + i, cx) + " " * cell_w)
        grid.append(rowcells)
        sep_rows.extend(range(cstart, cstart + content_h))
        r = cstart + content_h

    for c in range(maxcols - 1):
        sx = (c + 1) * (cell_w + 1)
        for rr in sep_rows:
            buf.append(at(rr, sx) + fg(SEP) + "│" + RESET)

    for ri, ci, cstart, cx, cw_, ch_, label, state, server in boxes:
        style = box_style(state, server)
        if ch_ >= 3 and cw_ >= 8:
            lab = crop_plain(label, cw_ - 6)
            interior = vis_width(lab) + 4
            bw = interior + 2
            bx = cx + max(0, (cw_ - bw) // 2)
            brow = cstart + max(0, (ch_ - 3) // 2)
            buf.append(at(brow, bx) + style + "┌" + "─" * interior + "┐" + RESET)
            buf.append(at(brow + 1, bx) + style + "│  " + lab + "  │" + RESET)
            buf.append(at(brow + 2, bx) + style + "└" + "─" * interior + "┘" + RESET)
        else:
            buf.append(at(cstart, cx) + style + crop_plain(f" {label} ", cw_) + RESET)

    # Heavy peach frame around the selected cell, drawn last so it sits on top of
    # content, separators and the label box.
    if sel is not None:
        for ri, ci, cstart, cx, cw_, ch_, label, state, server in boxes:
            if (ri, ci) != sel:
                continue
            if cw_ >= 2 and ch_ >= 2:
                hl = fg(PEACH) + BOLD
                top, bottom, left, right = cstart, cstart + ch_ - 1, cx, cx + cw_ - 1
                buf.append(at(top, left) + hl + "┏" + "━" * (cw_ - 2) + "┓" + RESET)
                for rr in range(top + 1, bottom):
                    buf.append(at(rr, left) + hl + "┃" + RESET)
                    buf.append(at(rr, right) + hl + "┃" + RESET)
                buf.append(at(bottom, left) + hl + "┗" + "━" * (cw_ - 2) + "┛" + RESET)
            break

    buf.append(at(rows, 1) + legend(cols))
    return "".join(buf), jumpmap, grid, hitboxes


def legend(cols):
    parts = [(BLUE, "● running"), (RED, "● waiting"), (YELLOW, "○ idle"), (GREEN, "■ server"), (DIM, "· other")]
    left = "  ".join(f"{fg(rgb)}{txt}{RESET}" for rgb, txt in parts)
    left_w = sum(vis_width(txt) for _, txt in parts) + 2 * (len(parts) - 1)
    hint = "hjkl move · ↵ open · 1-9/a-z/click jump · q quit"
    pad = max(1, cols - left_w - vis_width(hint) - 1)
    return f"{left}{' ' * pad}{fg(DIM)}{hint}{RESET}"


def main():
    if not sys.stdin.isatty():
        cols, rows = shutil.get_terminal_size((100, 30))
        sessions, wins, maxcols = gather()
        sys.stdout.write(build_frame(cols, rows, sessions, wins, maxcols, None, clear=True)[0])
        return
    run_live()


def move(sel, nav, grid):
    """Next selection after an hjkl/arrow move, wrapping at every edge.

    From no selection we enter the grid in the pressed direction: l → top-left,
    h → top-right, j → second row (col 0), k → last row (col 0). Once selected,
    h/l wrap within the session band and j/k wrap across bands (clamping the
    column into the target band, which may be shorter)."""
    nrows = len(grid)
    if nrows == 0:
        return None
    if sel is None:
        if nav == "l":
            return (0, 0)
        if nav == "h":
            return (0, len(grid[0]) - 1)
        if nav == "j":
            return (1 % nrows, 0)
        if nav == "k":
            return (nrows - 1, 0)
        return None
    r, c = sel
    if nav == "h":
        c = (c - 1) % len(grid[r])
    elif nav == "l":
        c = (c + 1) % len(grid[r])
    elif nav == "j":
        r = (r + 1) % nrows
        c = min(c, len(grid[r]) - 1)
    elif nav == "k":
        r = (r - 1) % nrows
        c = min(c, len(grid[r]) - 1)
    return (r, c)


def hit_test(hitboxes, x, y):
    for top, left, bottom, right, tgt in hitboxes:
        if top <= y <= bottom and left <= x <= right:
            return tgt
    return None


ARROWS = {"\x1b[A": "k", "\x1b[B": "j", "\x1b[C": "l", "\x1b[D": "h",
          "\x1bOA": "k", "\x1bOB": "j", "\x1bOC": "l", "\x1bOD": "h"}
MOUSE_RE = re.compile(r"\x1b\[<(\d+);(\d+);(\d+)([Mm])")


def run_live():
    import termios
    import tty

    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    target = None
    sel = None          # (band, col), or None until the first move
    try:
        tty.setraw(fd)
        # hide cursor, disable autowrap, clear, enable SGR mouse reporting
        sys.stdout.write(f"{ESC}[?25l{ESC}[?7l{ESC}[2J{ESC}[?1000h{ESC}[?1006h")
        prev = None
        while True:
            cols, rows = shutil.get_terminal_size((100, 30))
            sessions, wins, maxcols = gather()
            # drop a stale selection if the layout shrank under it
            if sel is not None and (
                sel[0] >= len(sessions)
                or sel[1] >= len(wins.get(sessions[sel[0]], []))
            ):
                sel = None
            dims = (cols, rows, len(sessions), maxcols)
            frame, jumpmap, grid, hitboxes = build_frame(
                cols, rows, sessions, wins, maxcols, sel, clear=dims != prev)
            sys.stdout.write(frame)
            sys.stdout.flush()
            prev = dims
            if not select.select([sys.stdin], [], [], INTERVAL)[0]:
                continue
            data = os.read(fd, 1024)
            if not data:
                continue
            s = data.decode("utf-8", "ignore")
            m = MOUSE_RE.search(s)
            if m:
                b, x, y, typ = int(m.group(1)), int(m.group(2)), int(m.group(3)), m.group(4)
                if typ == "M" and (b & 0xE3) == 0:        # left press, no motion/wheel
                    hit = hit_test(hitboxes, x, y)
                    if hit:
                        target = hit
                        break
                continue
            for seq, kk in ARROWS.items():
                if s.startswith(seq):
                    s = kk
                    break
            ch = s[0] if s else ""
            if len(s) == 1 and ch in "hjkl":
                sel = move(sel, ch, grid)
                continue
            if ch in ("\r", "\n"):
                if sel is not None:
                    target = grid[sel[0]][sel[1]]
                    break
                continue
            if ch in ("q", "\x1b", "\x03"):
                break
            if ch in jumpmap:
                target = jumpmap[ch]
                break
            # anything else: ignore (do not close)
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)
        # disable mouse, restore autowrap + cursor
        sys.stdout.write(f"{ESC}[?1000l{ESC}[?1006l{ESC}[?7h{ESC}[?25h{RESET}")
    if target:
        s, idx = target
        tmux("select-window", "-t", f"{s}:{idx}")
        tmux("switch-client", "-t", s)


if __name__ == "__main__":
    main()
