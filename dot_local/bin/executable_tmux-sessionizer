#!/usr/bin/env bash
# tmux-sessionizer — fuzzy project/workspace switcher, the tmux twin of the
# snacks.nvim Projects picker (which scans the same ~/workspace root).
#
# Bound to Alt+f (see dot_tmux.conf). Shows, in one fzf popup:
#   • every RUNNING workspace (tmux session)              — agent-state dot
#   • every PROJECT under ~/workspace not already open    — folder icon
#
# The session dot reuses the per-tab agent indicator palette (@agent_state, set
# per-window by the agent-state helper and rendered in dot_tmux.conf):
#   needs-input → red    ●   running → blue ●   idle → yellow ○   none → grey ●
# A session's dot is the highest-priority state across its windows, precedence
# needs-input > running > idle > none — so a single blocked or working window
# colours the whole session. Plain shell sessions (no agent ever) show grey ●.
# Open sessions are listed first (most-recently-attached order) and, thanks to
# fzf --no-sort, that grouping survives filtering — so a typed query never
# buries an open session below a project that happens to match better. The cost
# is that fzf no longer reorders by match score, so each group filters in its
# own input order (sessions by recency, projects alphabetically).
# Type to filter, Enter to jump. An open session is switched to; a not-yet-open
# project gets a fresh session named after its dir (tmux forbids . and :, so
# they squash to _) with `cc` (Claude) in the first tab and `nvim .` in a
# second tab (the nvim tab is selected) — the same create-or-switch shape as
# the `t.` shell function (dot_bash_aliases.tmpl), though this copy also captures
# the new pane id and routes the switch through go(). NOTE: that . / : → _ squash means two dirs like `a.b` and `a:b` map to
# the one session name `a_b`; the second is then hidden from the list (or jumps
# you to the first). Accepted — tmux simply can't name those two apart.
#
# Written bash-3.2-safe (macOS /usr/bin/bash): no associative arrays. Each fzf
# line is tab-separated  <display>\t<kind>\t<target> ; --with-nth=1 shows only
# the display column while the selection still carries kind+target to act on.
#
# A command run inside `display-popup` isn't tied to a client, so a bare
# `switch-client` no-ops. tmux does NOT expand #{client_name} in a popup command
# (it arrives as the literal string) and doesn't set $TMUX_PANE there either, so
# we identify the client ourselves: the most-recently-active one, which is
# whichever client just opened this popup. We then switch it by name with -c.
set -euo pipefail

WORKSPACE="$HOME/workspace"
TAB=$'\t'   # field delimiter for the tmux -F tables below; '|' is legal in a
            # session name (and would mis-split), a tab effectively never is.

# Switch that client to session $1 (attach if we somehow have no client/server).
# CLIENT is resolved lazily on first use — keeping that tmux call off the path
# to showing the popup, so fzf paints as early as possible.
CLIENT=""
go() {
  [ -z "$CLIENT" ] && CLIENT=$(tmux list-clients -F '#{client_activity} #{client_name}' \
    2>/dev/null | sort -rn | head -1 | cut -d' ' -f2- || true)
  if [ -n "$CLIENT" ]; then
    tmux switch-client -c "$CLIENT" -t "=$1"
  elif [ -n "${TMUX:-}" ]; then
    tmux switch-client -t "=$1"
  else
    tmux attach -t "=$1"
  fi
}

# Running sessions, most-recently-attached first (the useful jump order; with
# fzf --no-sort below this input order is preserved through filtering, so open
# sessions stay ranked above projects instead of intermixing by match score).
open_names=$(
  tmux list-sessions -F "#{session_last_attached}${TAB}#{session_name}" 2>/dev/null \
    | sort -t"$TAB" -k1,1 -rn | cut -d"$TAB" -f2 || true
)

# Aggregate @agent_state to a numeric rank per session in ONE awk pass over all
# windows (precedence needs-input 3 > running 2 > idle 1 > none/unset 0) — the
# previous version re-scanned this whole table once per session (O(sessions ×
# windows) on the popup's paint path). Emits "<session>\t<rank>"; a session whose
# windows are all none/unset is simply absent → rank 0 on the lookup below.
win_states=$(tmux list-windows -a -F "#{session_name}${TAB}#{@agent_state}" 2>/dev/null || true)
session_ranks=$(printf '%s\n' "$win_states" | awk -F"$TAB" '
  { r = $2=="needs-input" ? 3 : $2=="running" ? 2 : $2=="idle" ? 1 : 0 }
  r > seen[$1] { seen[$1] = r }
  END { for (s in seen) print s "\t" seen[s] }
')
ranks_nl=$'\n'"$session_ranks"$'\n'   # \n<name>\t<rank>\n … for fork-free lookup

# Set $_dot to the truecolor glyph for rank $1 (mirrors dot_tmux.conf's palette).
# Assigns a var rather than printing so the emit loop needs no $() per session.
rank_dot() {
  case "$1" in
    3) _dot=$'\033[38;2;243;139;168m●\033[0m' ;;  # needs-input  #f38ba8
    2) _dot=$'\033[38;2;137;180;250m●\033[0m' ;;  # running      #89b4fa
    1) _dot=$'\033[38;2;249;226;175m○\033[0m' ;;  # idle         #f9e2af
    *) _dot=$'\033[38;2;108;112;134m●\033[0m' ;;  # none / unset #6c7086
  esac
}

selected=$(
  {
    # Open workspaces first (recency order, already sorted), agent-state dotted.
    printf '%s\n' "$open_names" | while IFS= read -r s; do
      [ -z "$s" ] && continue
      r=0
      case "$ranks_nl" in
        *$'\n'"$s$TAB"*) r=${ranks_nl#*$'\n'"$s$TAB"}; r=${r%%$'\n'*} ;;
      esac
      rank_dot "$r"
      printf '%s  %s\tsession\t%s\n' "$_dot" "$s" "$s"
    done
    # Then projects under ~/workspace that aren't already open as a session.
    # Pure-bash, no per-dir forks: an earlier version ran basename + grep per
    # directory and that loop alone cost ~90ms (it dominated startup). Here the
    # glob lists dirs alphabetically (and skips dotdirs like .claude for free,
    # since pathname expansion ignores leading dots), parameter expansion does
    # the basename, and a newline-delimited substring match tests open-ness.
    if [ -d "$WORKSPACE" ]; then
      open_nl=$'\n'"$open_names"$'\n'            # \n<name>\n … \n for the match;
                                                 # wrap directly — $() would strip
                                                 # the trailing \n off the last name
      for d in "$WORKSPACE"/*/; do
        [ -d "$d" ] || continue                  # no-match glob stays literal
        d=${d%/}; base=${d##*/}                  # strip trailing / then dirname
        name=${base//[.:]/_}
        case "$open_nl" in *$'\n'"$name"$'\n'*) continue ;; esac
        printf '  %s\tdir\t%s\n' "$base" "$d"
      done
    fi
  } | fzf --ansi --no-sort --reverse --cycle --no-multi \
          --border=rounded --border-label=' Projects ' \
          --prompt='  ' --pointer='▶' --delimiter=$'\t' --with-nth=1 \
          --color='border:#cba6f7,label:#cba6f7,prompt:#89b4fa,pointer:#f38ba8,bg+:#45475a,fg+:#cdd6f4'
) || exit 0
[ -z "$selected" ] && exit 0

kind=$(printf '%s' "$selected" | cut -f2)
target=$(printf '%s' "$selected" | cut -f3)

if [ "$kind" = session ]; then
  go "$target"
else
  name=${target##*/}; name=${name//[.:]/_}   # basename + squash, as the projects
                                             # loop above does (tmux forbids . :)
  if ! tmux has-session -t "=$name" 2>/dev/null; then
    # Capture the new session's pane id for send-keys. send-keys needs a *pane*
    # target, and the "=name" exact-match form (fine for session lookups like
    # has-session) does NOT resolve as a pane — it errors, which under set -e
    # would abort the script before the switch below ever runs.
    pane=$(tmux new-session -d -P -F '#{pane_id}' -s "$name" -c "$target")
    tmux send-keys -t "$pane" cc Enter
    # Second tab (window) with nvim; no -d so it becomes the selected window.
    nvim_pane=$(tmux new-window -P -F '#{pane_id}' -t "=$name" -c "$target")
    tmux send-keys -t "$nvim_pane" 'nvim .' Enter
  fi
  go "$name"
fi
