#!/bin/sh
# tmux-url-open — pop up a tmux menu to open a local dev server or an on-screen
# URL in the system default browser. Bound from .tmux.conf to `prefix u`.
#
# Two sections, two key styles so they never collide and picking is fast:
#   Servers (1-9): every running `make serve` across ALL sessions, keyed off the
#     @server_port we track per window (see server-port-watch / the make
#     wrapper). Opens http://localhost:PORT. The server in the current tab is
#     marked →. This works workspace-wide, so a server in another session is one
#     keystroke away without switching to its tab.
#   URLs (a-z): every http(s) URL visible in the current pane.
#
# Replaces Ghostty's cmd-click URL-open, which tmux's `set -g mouse on` swallows
# before Ghostty sees it. Cross-platform (Darwin / Linux).

set -eu

case "$(uname)" in
    Darwin) opener=open ;;
    *)      opener=xdg-open ;;
esac

TAB=$(printf '\t')
cur=$(tmux display-message -p '#{session_name}:#{window_index}')   # this tab

# Escape single quotes so a value is safe inside a single-quoted shell word.
shquote() { printf '%s' "$1" | sed "s/'/'\\\\''/g"; }

# ---- servers across the whole workspace -------------------------------------
# -a spans every session; keep only windows whose tab is flagged running with a
# detected port. Fields: PORT \t session:index \t name.
servers=$(
    tmux list-windows -a -F "#{@server_port}${TAB}#{@server_state}${TAB}#{session_name}:#{window_index}${TAB}#{window_name}" \
        | awk -F"$TAB" '$2=="running" && $1!="" { print $1 FS $3 FS $4 }'
)

# ---- http(s) URLs in the current pane ---------------------------------------
# -J joins wrapped lines so a split URL comes back whole. Trailing punctuation
# (.,;:) and an unbalanced ) are common in logs/markdown — strip them. Dedupe
# in first-seen order; cap at 26 so each gets a unique a..z key.
urls=$(
    tmux capture-pane -J -p \
        | grep -oE 'https?://[A-Za-z0-9._~:/?#@!$&()*+,;=%-]+' \
        | sed -E 's/[.,;:)]+$//' \
        | awk '!seen[$0]++' \
        | head -n 26
)

# Build display-menu arg triplets in "$@": <label> <hotkey> <tmux-command>.
# A label starting with "-" is a dimmed, non-selectable section header; an empty
# label is a horizontal rule. Two quirks learned the hard way (tmux 3.6):
#   * tmux SWALLOWS the very first menu item if it's non-selectable, so the
#     servers section leads with a throwaway empty item to let its header show.
#   * #[...] styles in an item *name* corrupt tmux's width maths and the row gets
#     truncated with a ">", so labels are kept PLAIN. Clarity instead comes from
#     the headers, the digit-vs-letter keys, and flush-left alignment (every row
#     carries only the box's one-space padding, so ports and URLs line up).
set --
srv_urls=""   # localhost URLs we've shown as servers, to dedupe the URL list
n=0

if [ -n "$servers" ]; then
    set -- "" "" ""                              # absorbed; lets the header show
    set -- "$@" "-servers · all sessions" "" ""
    while IFS="$TAB" read -r port loc name; do
        [ -n "$port" ] || continue
        n=$((n + 1))
        if [ "$n" -le 9 ]; then key="$n"; else key=""; fi
        url="http://localhost:$port"
        srv_urls="$srv_urls$url$TAB"
        here=""
        [ "$loc" = "$cur" ] && here=" ←"
        cmd="run-shell -b \"$opener '$(shquote "$url")'\""
        label=$(printf ':%-5s %s  %s%s' "$port" "$name" "$loc" "$here")
        set -- "$@" "$label" "$key" "$cmd"
    done <<EOF
$servers
EOF
fi

if [ -n "$urls" ]; then
    i=0
    header_done=
    while IFS= read -r url; do
        [ -n "$url" ] || continue
        # Skip an on-screen URL that's already listed as a server.
        case "$srv_urls" in *"$url$TAB"*) continue ;; esac
        if [ -z "$header_done" ]; then
            [ "$n" -gt 0 ] && set -- "$@" "" "" ""   # rule between sections
            set -- "$@" "-urls · this pane" "" ""
            header_done=1
        fi
        hotkey=$(awk -v c=$((97 + i)) 'BEGIN { printf "%c", c }')   # a, b, c, …
        i=$((i + 1))
        cmd="run-shell -b \"$opener '$(shquote "$url")'\""
        label=$(printf '%s' "$url" | cut -c1-90)
        set -- "$@" "$label" "$hotkey" "$cmd"
    done <<EOF
$urls
EOF
fi

if [ "$#" -eq 0 ]; then
    tmux display-message "tmux-url-open: no servers or URLs found"
    exit 0
fi

# -H sets the selected-row style: a subtle surface-1 background (instead of the
# default reverse video) so the green port / dim location stay legible.
tmux display-menu -T ' open ' -H 'bg=#45475a' -x C -y C "$@"
