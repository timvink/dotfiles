#!/bin/sh
# tmux-url-open — pop up a tmux menu to open a local dev server or an on-screen
# URL in the system default browser. Bound from .tmux.conf to `prefix u`.
#
# Two sections, two key styles so they never collide and picking is fast:
#   Servers (1-9): every running `make serve` across ALL sessions, keyed off the
#     @server_port we track per window (see server-port-watch / the make
#     wrapper). Opens http://localhost:PORT. The server in the current tab is
#     marked →. This works workspace-wide, so a server in another session is one
#     keystroke away without switching to its tab.
#   URLs (a-z): every URL visible in the current pane — including bare domains
#     like dashboard.stripe.com/... that carry no http(s):// scheme (these are
#     normalised to https:// so the opener treats them as URLs, not files).
#
# Press `q` to drop into "kill mode": the same menu, servers only, where the
# digit keys send C-c to a server's pane (a graceful stop — the make wrapper's
# INT trap shuts the server down and clears the tab's port chip) instead of
# opening it. Reached by re-invoking ourselves as `tmux-url-open kill`. `q`
# works as a mnemonic even though tmux documents it as "exit menu": item key
# shortcuts are matched before the built-in keys (see menu.c menu_key_cb), the
# same reason the cheatsheet's `q` row fires.
#
# Replaces Ghostty's cmd-click URL-open, which tmux's `set -g mouse on` swallows
# before Ghostty sees it. Cross-platform (Darwin / Linux).

set -eu

# "open" (default) builds the open menu; "kill" builds the servers-only kill
# menu. The open menu's `q` row re-invokes us with this arg.
mode="${1:-open}"

case "$(uname)" in
    Darwin) opener=open ;;
    *)      opener=xdg-open ;;
esac

TAB=$(printf '\t')
cur=$(tmux display-message -p '#{session_name}:#{window_index}')   # this tab

# Escape single quotes so a value is safe inside a single-quoted shell word.
shquote() { printf '%s' "$1" | sed "s/'/'\\\\''/g"; }

# Escape a display-menu item *name* for tmux's format engine: a literal '#'
# (URL fragments like #section, or a '#' in a window name) is otherwise read as
# the start of '#[style]', '#{format}' or even '#(run-shell)', which corrupts
# the row's width maths (truncating it with a ">") or runs a command. Doubling
# '#'→'##' makes tmux render a single literal '#'. (See the quirks note below.)
menulabel() { printf '%s' "$1" | sed 's/#/##/g'; }

# Fit a URL into $2 columns. A plain end-cut hides the part that actually tells
# two long URLs apart (same host + path, differing only in a tail beyond the
# cut), so instead keep the scheme://host/ prefix and as much of the tail as
# fits, joined by a middle ellipsis: https://dev.azure.com/…/nwf-foo.git
ellipsize_url() {
    url=$1; max=$2
    [ "${#url}" -le "$max" ] && { printf '%s' "$url"; return; }
    # prefix = everything through the first slash after the authority. If the
    # URL has no path slash, this matches nothing and we fall back to end-cut.
    prefix=$(printf '%s' "$url" | sed -nE 's#^([a-z][a-z0-9+.-]*://[^/]*/).*#\1#p')
    # tail budget = max minus the prefix and the 1-column ellipsis. If the
    # prefix alone won't fit (or there was none), just hard end-cut.
    tail_len=$((max - ${#prefix} - 1))
    if [ -z "$prefix" ] || [ "$tail_len" -lt 1 ]; then
        printf '%s' "$url" | cut -c1-"$max"
        return
    fi
    tail=$(printf '%s' "$url" | awk -v n="$tail_len" '{ print substr($0, length($0)-n+1) }')
    printf '%s…%s' "$prefix" "$tail"
}

# ---- servers across the whole workspace -------------------------------------
# -a spans every session; keep only windows whose tab is flagged running with a
# detected port. Fields: PORT \t session:index \t name.
servers=$(
    tmux list-windows -a -F "#{@server_port}${TAB}#{@server_state}${TAB}#{session_name}:#{window_index}${TAB}#{window_name}" \
        | awk -F"$TAB" '$2=="running" && $1!="" { print $1 FS $3 FS $4 }'
)

# ---- URLs in the current pane -----------------------------------------------
# -J joins wrapped lines so a split URL comes back whole. Two kinds are matched
# (one alternation, leftmost-longest so a scheme URL always wins over its bare
# tail at the same spot):
#   1. scheme URLs: https?://…
#   2. bare domains: host.tld[/path] with no scheme, e.g. dashboard.stripe.com/x.
#      Bare matching is gated on a curated TLD list (see $tld) so it fires on
#      real domains but NOT on filenames (README.md, main.rs, app.py), version
#      strings (v1.2.3) or prose — their trailing token isn't a listed TLD. The
#      \b after the TLD stops dashboard.community truncating to dashboard.com.
#      A negative lookbehind also rejects a bare domain glued to a preceding
#      email-local-part char ([A-Za-z0-9@_.-]), so vinktim@gmail.com (my own
#      address, shown on the status line) no longer surfaces gmail.com. Scheme
#      URLs match independently, so https://user@host.com keeps its userinfo.
#      The lookbehind needs PCRE, hence perl rather than POSIX `grep -oE`.
# Then: strip trailing punctuation (.,;:) and an unbalanced ) common in
# logs/markdown; normalise bare domains to https:// (so `open`/xdg-open treats
# them as URLs, not local files); dedupe keeping the first occurrence, then emit
# in reverse (last-discovered first) so the most recent on-screen URL sits at the
# top of the menu with hotkey `a`. The a..z key cap
# (26) is applied in the loop below, AFTER server URLs are filtered out — capping
# here would let localhost servers eat slots and silently drop on-screen URLs.
# Only the open menu lists on-screen URLs; kill mode is servers-only.
#
# $tld leaves out real TLDs that collide with common code-file extensions
# (md/rs/sh/…) to avoid false hits; add any you actually use as web addresses.
tld='com|org|net|edu|gov|mil|int|info|biz|io|dev|app|ai|co|xyz|online|site|tech|cloud|nl|be|de|fr|uk|eu|us|ca|au|es|it|se|no|dk|fi|pl|ch|at|ie'
if [ "$mode" = open ]; then
    urls=$(
        tmux capture-pane -J -p \
            | TLD="$tld" perl -ne '
                my $c = qr/[A-Za-z0-9._~:\/?#\@!\$&()*+,;=%-]/;
                while (/(https?:\/\/$c+)|(?<![A-Za-z0-9\@_.\-])((?:[A-Za-z0-9-]+\.)+(?:$ENV{TLD})\b(?::[0-9]+)?(?:\/$c*)?)/g) {
                    print defined($1) ? "$1\n" : "$2\n";
                }
            ' \
            | sed -E 's/[.,;:)]+$//' \
            | sed -E '\#^https?://#!s#^#https://#' \
            | awk '!seen[$0]++ { a[++n]=$0 } END { for (i = n; i >= 1; i--) print a[i] }'
    )
else
    urls=""
fi

# Build display-menu arg triplets in "$@": <label> <hotkey> <tmux-command>.
# A label starting with "-" is a dimmed, non-selectable section header; an empty
# label is a horizontal rule. Two quirks learned the hard way (tmux 3.6):
#   * tmux SWALLOWS the very first menu item if it's non-selectable, so the
#     servers section leads with a throwaway empty item to let its header show.
#   * #[...] styles in an item *name* corrupt tmux's width maths and the row gets
#     truncated with a ">", so labels are kept PLAIN. Clarity instead comes from
#     the headers, the digit-vs-letter keys, and flush-left alignment (every row
#     carries only the box's one-space padding, so ports and URLs line up).
set --
srv_urls=""   # localhost URLs we've shown as servers, to dedupe the URL list
n=0

if [ -n "$servers" ]; then
    set -- "" "" ""                              # absorbed; lets the header show
    if [ "$mode" = kill ]; then
        set -- "$@" "-kill a server · sends C-c to its pane" "" ""
    else
        set -- "$@" "-servers · all sessions" "" ""
    fi
    while IFS="$TAB" read -r ports_field loc name; do
        [ -n "$ports_field" ] || continue
        here=""
        [ "$loc" = "$cur" ] && here=" ←"
        # @server_port may hold several space-separated ports (a compose stack);
        # list each as its own pickable entry.
        for port in $ports_field; do
            n=$((n + 1))
            if [ "$n" -le 9 ]; then key="$n"; else key=""; fi
            url="http://localhost:$port"
            if [ "$mode" = kill ]; then
                # @server_state/@server_port are window-scoped, so we only know
                # the window — target it and its active pane gets the C-c (the
                # serve pane, normally). The make wrapper traps INT, so this is
                # the same graceful stop as hitting Ctrl-C in that tab.
                cmd="send-keys -t '$(shquote "$loc")' C-c"
            else
                srv_urls="$srv_urls$url$TAB"
                cmd="run-shell -b \"$opener '$(shquote "$url")'\""
            fi
            label=$(printf ':%-5s %s  %s%s' "$port" "$name" "$loc" "$here")
            set -- "$@" "$(menulabel "$label")" "$key" "$cmd"
        done
    done <<EOF
$servers
EOF
fi

if [ -n "$urls" ]; then
    i=0
    header_done=
    while IFS= read -r url; do
        [ -n "$url" ] || continue
        # Skip an on-screen URL that's already listed as a server.
        case "$srv_urls" in *"$url$TAB"*) continue ;; esac
        # Only a..z keys available; stop once they're spent (after server-dedup,
        # so real URLs aren't crowded out by localhost servers — see capture above).
        [ "$i" -ge 26 ] && break
        if [ -z "$header_done" ]; then
            # Always emit an empty item before the header. When servers precede
            # us it reads as the rule between sections; when URLs are the first
            # (and only) section it's the throwaway tmux swallows — and, crucially,
            # it keeps the "-"-prefixed header off the front of display-menu's arg
            # list, where tmux would parse "-urls…" as flags (-> "unknown flag -u").
            set -- "$@" "" "" ""
            set -- "$@" "-urls · this pane" "" ""
            header_done=1
        fi
        hotkey=$(awk -v c=$((97 + i)) 'BEGIN { printf "%c", c }')   # a, b, c, …
        i=$((i + 1))
        cmd="run-shell -b \"$opener '$(shquote "$url")'\""
        label=$(ellipsize_url "$url" 90)
        set -- "$@" "$(menulabel "$label")" "$hotkey" "$cmd"
    done <<EOF
$urls
EOF
fi

# Open menu only: a `q` row into kill mode, but only when there's a server to
# kill. It re-invokes us as `… kill` from within the (closing) menu, the same
# nested run-shell the cheatsheet's `u` row uses to reach this very menu.
if [ "$mode" = open ] && [ -n "$servers" ]; then
    set -- "$@" "" "" ""
    set -- "$@" "kill a server…" "q" "run-shell -b \"$0 kill\""
fi

if [ "$#" -eq 0 ]; then
    if [ "$mode" = kill ]; then
        tmux display-message "tmux-url-open: no servers running"
    else
        tmux display-message "tmux-url-open: no servers or URLs found"
    fi
    exit 0
fi

# -H sets the selected-row style: a subtle surface-1 background (instead of the
# default reverse video) so the green port / dim location stay legible.
[ "$mode" = kill ] && title=' kill ' || title=' open '
tmux display-menu -T "$title" -H 'bg=#45475a' -x C -y C "$@"
