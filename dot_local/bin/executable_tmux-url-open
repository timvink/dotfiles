#!/bin/sh
# tmux-url-open — pop up a tmux menu of every http(s) URL visible in the
# current pane and open the chosen one in the system default browser.
# Cross-platform (Darwin / Linux).
#
# Bound from .tmux.conf to `prefix u`. This replaces Ghostty's cmd-click
# URL-open, which tmux's `set -g mouse on` swallows before Ghostty sees it.

set -eu

case "$(uname)" in
    Darwin) opener=open ;;
    *)      opener=xdg-open ;;
esac

# -J joins wrapped lines so URLs split across rows come back as one match.
# Trailing punctuation (.,;:) and an unbalanced closing paren are common in
# log lines / markdown links — strip them so we don't open a broken URL.
# Dedupe in first-seen order; cap at 26 so each entry gets a unique a..z key.
urls=$(
    tmux capture-pane -J -p \
        | grep -oE 'https?://[A-Za-z0-9._~:/?#@!$&()*+,;=%-]+' \
        | sed -E 's/[.,;:)]+$//' \
        | awk '!seen[$0]++' \
        | head -n 26
)

if [ -z "$urls" ]; then
    tmux display-message "tmux-url-open: no URLs in pane"
    exit 0
fi

# Build display-menu arg triplets in "$@": <label> <hotkey> <tmux-command>.
# The here-doc form keeps the loop in this shell, so $@ survives past `done`.
i=0
set --
while IFS= read -r url; do
    [ -n "$url" ] || continue
    # Hotkey: 'a' + i  ⇒  a, b, c, …, z
    hotkey=$(awk -v n=$((97 + i)) 'BEGIN { printf "%c", n }')
    # Escape single quotes in the URL for safe single-quoted shell embedding.
    safe=$(printf '%s' "$url" | sed "s/'/'\\\\''/g")
    # tmux command: parsed by tmux (double-quoted), then by /bin/sh (URL is
    # single-quoted so the shell treats it literally — no glob/var expansion).
    cmd="run-shell -b \"$opener '$safe'\""
    label=$(printf '%s' "$url" | cut -c1-90)
    set -- "$@" "$label" "$hotkey" "$cmd"
    i=$((i + 1))
done <<EOF
$urls
EOF

tmux display-menu -T ' open URL ' -x C -y C "$@"
